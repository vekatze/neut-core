import {
  this.bool {and, any, bool},
  this.box,
  this.either {Left, Right, either},
  this.int.parse {parse-hex},
  this.list {Cons, List, Nil, concat, for-each-E, for-each-EN, intercalate, list},
  this.pair {Pair},
  this.rune,
  this.rune.eq {eq-rune},
  this.rune.ord {le-rune},
  this.string {
    drop,
    format,
    length,
    singleton,
    split,
    string,
    take-while-N,
  },
}

define _is-lower-hex-digit(r: rune) -> bool {
  any[
    and(le-rune(`0`, r), le-rune(r, `9`)),
    and(le-rune(`a`, r), le-rune(r, `f`)),
  ]
}

data error {
| Parse-Error(string)
}

define _read-char(r: rune, t: string) -> either(error, string) {
  match this.string.uncons(t) {
  | Right(Pair(r-found, rest)) =>
    if eq-rune(r, r-found) {
      Right(rest)
    } else {
      Left(Parse-Error(format("Expected `{}`, but got: `{}`", List[singleton(r), singleton(r-found)])))
    }
  | Left(_) =>
    Left(Parse-Error(format("Expected `{}`, but got: end of string", List[singleton(r)])))
  }
}

define _read-unicode-scalar-value(t: &string) -> either(error, rune) {
  match parse-hex(t) {
  | Left(_) =>
    Left(Parse-Error(format("Could not parse `{}` as a hexadecimal integer", List[*t])))
  | Right(v) =>
    match this.rune.from-int(v) {
    | Right(r) =>
      Right(r)
    | Left(_) =>
      Left(Parse-Error(format("The value `{}` is outside the Unicode codespace", List[*t])))
    }
  }
}

define _unquote-string(t: string) -> either(error, list(string)) {
  match this.string.uncons(t) {
  | Left(_) =>
    Right(List[*"\\"])
  | Right(Pair(c, rest)) =>
    if eq-rune(c, `0`) {
      Right(List[*"\u{0}", rest])
    } else-if eq-rune(c, `t`) {
      Right(List[*"\u{9}", rest])
    } else-if eq-rune(c, `n`) {
      Right(List[*"\u{A}", rest])
    } else-if eq-rune(c, `r`) {
      Right(List[*"\u{B}", rest])
    } else-if eq-rune(c, `"`) {
      Right(List[*"\u{22}", rest])
    } else-if eq-rune(c, `\\`) {
      Right(List[*"\u{5C}", rest])
    } else-if eq-rune(c, `\``) {
      Right(List[*"\u{60}", rest])
    } else-if eq-rune(c, `u`) {
      try rest = _read-char(`{`, rest);
      let hex-string on rest = take-while-N(rest, _is-lower-hex-digit);
      pin hex-string = hex-string;
      let scalar-value-string-len = length(hex-string);
      let rest = drop(rest, scalar-value-string-len);
      try rest = _read-char(`}`, rest);
      try r = _read-unicode-scalar-value(hex-string);
      Right(List[singleton(r), rest])
    } else {
      Left(Parse-Error(format("Unknown escape sequence: \\{}", List[singleton(c)])))
    }
  }
}

define _parse-string-fragment(t: &string) -> either(error, list(string)) {
  match split(t, "\\") {
  | Nil =>
    // unreachable
    Left(Parse-Error(*"(core).string.parse._parse-string-fragment"))
  | Cons(t, ts) =>
    try fragment-lists = for-each-E(ts, _unquote-string);
    Right(Cons(t, concat(fragment-lists)))
  }
}

define parse-string(t: &string) -> either(error, string) {
  pin ts = split(t, "\\\\");
  try tss = for-each-EN(ts, _parse-string-fragment);
  Right(this.string.join(this.list.concat(intercalate(tss, List[*"\\"]))))
}
