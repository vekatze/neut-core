import {
  this.binary {binary},
  this.binary.eq {eq-binary},
  this.bool {False, True, bool},
  this.eq {Eq, eq},
  this.list {Cons, Nil, list},
  this.pair {Pair, pair},
  this.string,
  this.string.meta,
  this.type-value {
    Algebraic,
    Binary,
    Constructor,
    Enum,
    Field,
    Float16,
    Float32,
    Float64,
    Int1,
    Int16,
    Int2,
    Int32,
    Int4,
    Int64,
    Int8,
    Rune,
    Vector,
    Wrapper,
    constructor,
    field,
  },
  this.type-value.meta {
    algebraic-discriminant,
    algebraic-header-slot-count,
    constructor-switch,
    data-arg-count,
    field-pointer,
    fields-with-cursors,
  },
  this.unsafe {cast, cast-inline},
  this.vector {vector},
}

nominal {
  define-meta eq-data<a>(x: '&a, y: '&a) -> 'bool,
}

inline-meta _equal-vector<a>(xs: '&vector(a), ys: '&vector(a)) -> 'bool {
  quote {
    let len-x = this.vector.length(unquote {xs});
    let len-y = this.vector.length(unquote {ys});
    if eq-int(len-x, len-y) {
      this.vector.zip-fold(unquote {xs}, unquote {ys}, True, (x: &a, y: &a, acc: bool, _: int) => {
        if acc {
          unquote {eq-data(quote {x}, quote {y})}
        } else {
          False
        }
      })
    } else {
      False
    }
  }
}

inline-meta _eq-data-adt-fields<a>(
  field-cursors: list(pair(field, int)),
  data-arg-num: int,
  header: int,
  x: '&a,
  y: '&a,
) -> 'bool {
  match field-cursors {
  | Nil =>
    quote {True}
  | Cons(!entry, rest) =>
    let Pair(f-raw, cursor) = entry;
    let !f = f-raw;
    let Field(_, t, _) = f;
    unpack-type t = t;
    quote {
      let x-elem-ptr = cast-inline<pointer, &t>(unquote {field-pointer(f, header, data-arg-num, cursor, x)});
      let y-elem-ptr = cast-inline<pointer, &t>(unquote {field-pointer(f, header, data-arg-num, cursor, y)});
      let is-eq = unquote {eq-data(quote {x-elem-ptr}, quote {y-elem-ptr})};
      if is-eq {
        unquote {_eq-data-adt-fields(rest, data-arg-num, header, x, y)}
      } else {
        False
      }
    }
  }
}

inline-meta _eq-data-adt<a>(
  constructors: list(constructor),
  data-arg-num: int,
  header: int,
  disc: 'int,
  x: '&a,
  y: '&a,
) -> 'bool {
  constructor-switch(constructors, disc, quote {True}, (c) => {
    let Constructor(_, _, xts) = c;
    _eq-data-adt-fields(fields-with-cursors(xts, 0), data-arg-num, header, x, y)
  })
}

define-meta eq-data<a>(x: '&a, y: '&a) -> 'bool {
  let k = magic inspect-type(a);
  match k {
  | Algebraic(_, data-args, !cons-info) =>
    let data-arg-num = data-arg-count(data-args);
    let header = algebraic-header-slot-count(cons-info);
    quote {
      let discriminant-x = unquote {algebraic-discriminant(cons-info, x)};
      let discriminant-y = unquote {algebraic-discriminant(cons-info, y)};
      if ne-int(discriminant-x, discriminant-y) {
        False
      } else {
        unquote {_eq-data-adt(cons-info, data-arg-num, header, quote {discriminant-x}, x, y)}
      }
    }
  | Enum(_) =>
    quote {
      let discriminant-x = cast<&a, int>(unquote {x});
      let discriminant-y = cast<&a, int>(unquote {y});
      eq-int(discriminant-x, discriminant-y)
    }
  | Int1 =>
    quote {
      let x = cast<&a, int1>(unquote {x});
      let y = cast<&a, int1>(unquote {y});
      eq-int1(x, y)
    }
  | Int2 =>
    quote {
      let x = cast<&a, int2>(unquote {x});
      let y = cast<&a, int2>(unquote {y});
      eq-int2(x, y)
    }
  | Int4 =>
    quote {
      let x = cast<&a, int4>(unquote {x});
      let y = cast<&a, int4>(unquote {y});
      eq-int4(x, y)
    }
  | Int8 =>
    quote {
      let x = cast<&a, int8>(unquote {x});
      let y = cast<&a, int8>(unquote {y});
      eq-int8(x, y)
    }
  | Int16 =>
    quote {
      let x = cast<&a, int16>(unquote {x});
      let y = cast<&a, int16>(unquote {y});
      eq-int16(x, y)
    }
  | Int32 =>
    quote {
      let x = cast<&a, int32>(unquote {x});
      let y = cast<&a, int32>(unquote {y});
      eq-int32(x, y)
    }
  | Int64 =>
    quote {
      let x = cast<&a, int64>(unquote {x});
      let y = cast<&a, int64>(unquote {y});
      eq-int64(x, y)
    }
  | Float16 =>
    quote {
      let x = cast<&a, float16>(unquote {x});
      let y = cast<&a, float16>(unquote {y});
      eq-float16(x, y)
    }
  | Float32 =>
    quote {
      let x = cast<&a, float32>(unquote {x});
      let y = cast<&a, float32>(unquote {y});
      eq-float32(x, y)
    }
  | Float64 =>
    quote {
      let x = cast<&a, float64>(unquote {x});
      let y = cast<&a, float64>(unquote {y});
      eq-float64(x, y)
    }
  | Rune =>
    quote {
      let x = cast<&a, rune>(unquote {x});
      let y = cast<&a, rune>(unquote {y});
      eq-rune(x, y)
    }
  | Binary =>
    quote {
      let x = cast<&a, &binary>(unquote {x});
      let y = cast<&a, &binary>(unquote {y});
      eq-binary(x, y)
    }
  | Vector(t) =>
    unpack-type t = t;
    quote {
      let x: &vector(t) = cast<&a, &vector(t)>(unquote {x});
      let y: &vector(t) = cast<&a, &vector(t)>(unquote {y});
      unquote {_equal-vector<t>(quote {x}, quote {y})}
    }
  | Wrapper(t) =>
    unpack-type t = t;
    quote {
      let x: &t = cast<&a, &t>(unquote {x});
      let y: &t = cast<&a, &t>(unquote {y});
      unquote {eq-data(quote {x}, quote {y})}
    }
  | _ =>
    let t = magic show-type(a);
    let message = this.string.meta.append("eq-data doesn't support: ", t);
    magic compile-error(message)
  }
}

define-meta derive<a>() -> 'eq(a) {
  quote {
    Eq{
      equal := {
        (x, y) => {
          eq-data::(x, y)
        }
      },
    }
  }
}
