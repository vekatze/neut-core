import {
  this.bool {bool},
  this.box,
  this.show {Show, show},
  this.string {string},
}

constant as-show: show(bool) {
  Show((b) => {
    if *b {
      *"True"
    } else {
      *"False"
    }
  })
}

define show(b: bool) -> string {
  let Show{render} = as-show;
  pin b = b;
  render(b)
}

define show-bool(b: bool) -> string {
  this.bool.show.show(b)
}
