import {
  this.either {Left, Right},
  this.file.descriptor {stdin, stdout},
  this.string,
  this.string.io {print, read, write},
  this.system {get-error-message},
  this.unit {unit},
}

define zen() -> unit {
  // print("hey\n");
  // Unit
  let _ = write(stdout, "hello.\n");
  let value = read(stdin, 10);
  match value {
  | Right(_) =>
    print("success\n")
  | Left(e) =>
    pin string = get-error-message(e);
    print(string);
    print("\n")
  }
}
