import {
  this.bool,
  this.either {Left, Right},
  this.file.descriptor {descriptor, stdout},
  this.string,
  this.string.io {print},
  this.system {report-system-error, system},
  this.unit {Unit, unit},
}

foreign {
  neut_core_v0_52_write_double(int32, float, int): int,
  neut_core_v0_52_write_double_line(int32, float, int): int,
}

define write-float(d: descriptor, x: float, decimals: int) ->> system(unit) {
  let d = magic cast(descriptor, int32, d);
  let result = magic external neut_core_v0_52_write_double(d, x, decimals);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define write-float-line(d: descriptor, x: float, decimals: int) ->> system(unit) {
  let d = magic cast(descriptor, int32, d);
  let result = magic external neut_core_v0_52_write_double_line(d, x, decimals);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define print-float(x: float, decimals: int) -> unit {
  match write-float(stdout, x, decimals) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define print-float-line(x: float, decimals: int) -> unit {
  match write-float-line(stdout, x, decimals) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define zen() -> unit {
  print-float(1234.56789, 2);
  print("\n");
  print-float-line(123.45, 7)
}
