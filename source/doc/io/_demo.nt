import {
  this.ansi {Blue, Yellow},
  this.box,
  this.doc {Group, Nest, ansi-fg, ansi-reset, atom, break, join},
  this.doc.io {print-doc-line},
  this.string,
  this.unit {Unit, unit},
}

define zen() -> unit {
  pin item =
    Group(join[
      ansi-fg(Blue),
      atom(*"begin"),
      ansi-reset,
      Nest(2, join[
        break(" "),
        Group(
          join[
            ansi-fg(Yellow),
            atom(*"print;"),
            ansi-reset,
            break(" "),
            atom(*"test;"),
            break(" "),
            atom(*"stmt;"),
          ],
        ),
      ]),
      break(" "),
      ansi-fg(Blue),
      atom(*"end"),
      ansi-reset,
    ]);
  print-doc-line(item, 20);
  Unit
}
