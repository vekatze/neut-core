import {
  this.ansi {Blue, Yellow},
  this.binary,
  this.bool,
  this.doc {
    Chunk,
    Chunk-Choose,
    Chunk-Empty,
    Chunk-Join,
    Chunk-Line,
    Chunk-String-N,
    Group,
    Nest,
    ansi-bold,
    ansi-fg,
    ansi-reset,
    atom,
    atom-N,
    atom-float,
    atom-int,
    atom-rune,
    break,
    doc,
    empty,
    join,
  },
  this.doc.show {show-doc},
  this.float.show {show-float32},
  this.list {Cons, Nil, list},
  this.pair {Pair, pair},
  this.show {Show, show},
  this.string {string},
  this.type-value {
    Algebraic,
    Binary,
    Box-T,
    Constructor,
    Enum,
    Field,
    Float16,
    Float32,
    Float64,
    Int1,
    Int16,
    Int2,
    Int32,
    Int4,
    Int64,
    Int8,
    Noema,
    Null,
    Pointer,
    Rune,
    Vector,
    Wrapper,
    constructor,
    field,
  },
  this.type-value.meta {
    algebraic-discriminant,
    algebraic-header-slot-count,
    constructor-switch,
    data-arg-count,
    enum-switch,
    field-pointer,
    fields-with-cursors,
  },
  this.unsafe {cast-inline},
  this.vector {vector},
}

define _literal-doc(d: doc) -> doc {
  join[
    ansi-fg(Yellow),
    d,
    ansi-reset,
  ]
}

nominal {
  define-meta to-doc<a>(x: '&a) -> 'doc,
}

define _constructor-doc(x: &string) -> doc {
  join[
    ansi-fg(Blue),
    ansi-bold,
    atom-N(x),
    ansi-reset,
  ]
}

define _nested-comma-seq(prefix: doc, body: doc, suffix: doc) -> doc {
  join[
    prefix,
    Nest(
      2,
      join[
        break(""),
        Group(body),
      ],
    ),
    Chunk(Chunk-Choose(Chunk-Empty, Chunk-Join(Chunk-String-N(","), Chunk-Line))),
    suffix,
  ]
}

inline-meta _vector-doc<a>(xs: '&vector(a)) -> 'doc {
  quote {
    let prefix = join[_constructor-doc("Vector"), atom-N("[")];
    let suffix = atom-N("]");
    let len = this.vector.length(unquote {xs});
    let content =
      this.vector.fold-right-N(unquote {xs}, empty, (x: &a, acc: doc, i: int) => {
        if eq-int(add-int(i, 1), len) {
          join[unquote {to-doc(quote {x})}, acc]
        } else {
          join[unquote {to-doc(quote {x})}, atom-N(","), break(" "), acc]
        }
      });
    Group(_nested-comma-seq(
      prefix,
      content,
      suffix,
    ))
  }
}

inline-meta _constructor-arg-doc<a>(
  !f: field,
  cursor: int,
  header: int,
  data-arg-num: int,
  x: '&a,
) -> 'doc {
  let Field(_, t, _) = f;
  unpack-type t = t;
  quote {
    let x-elem-ptr = cast-inline<pointer, &t>(unquote {field-pointer(f, header, data-arg-num, cursor, x)});
    unquote {to-doc<t>(quote {x-elem-ptr})}
  }
}

inline-meta _constructor-args-doc<a>(
  field-cursors: list(pair(field, int)),
  header: int,
  data-arg-num: int,
  x: '&a,
) -> 'doc {
  match field-cursors {
  | Nil =>
    quote {empty}
  | Cons(entry, Nil) =>
    let Pair(f, cursor) = entry;
    _constructor-arg-doc(f, cursor, header, data-arg-num, x)
  | Cons(!entry, rest) =>
    let Pair(f, cursor) = entry;
    let d1 = _constructor-arg-doc(f, cursor, header, data-arg-num, x);
    let d2 = _constructor-args-doc(rest, header, data-arg-num, x);
    quote {join[unquote {d1}, atom-N(","), break(" "), unquote {d2}]}
  }
}

inline-meta _algebraic-constructor-doc<a>(
  cons: constructor,
  header: int,
  data-arg-num: int,
  x: '&a,
) -> 'doc {
  let Constructor(cons-name, is-const-like, xts) = cons;
  let prefix =
    if is-const-like {
      quote {_constructor-doc(unquote {promote {cons-name}})}
    } else {
      quote {join[_constructor-doc(unquote {promote {cons-name}}), atom-N("(")]}
    };
  let suffix =
    if is-const-like {
      quote {empty}
    } else {
      quote {atom-N(")")}
    };
  quote {
    Group(_nested-comma-seq(
      unquote {prefix},
      unquote {_constructor-args-doc(fields-with-cursors(xts, 0), header, data-arg-num, x)},
      unquote {suffix},
    ))
  }
}

inline-meta _algebraic-doc<a>(
  constructors: list(constructor),
  header: int,
  data-arg-num: int,
  disc: 'int,
  x: '&a,
) -> 'doc {
  constructor-switch(constructors, disc, quote {empty}, (cons) => {
    _algebraic-constructor-doc(cons, header, data-arg-num, x)
  })
}

define-meta to-doc<a>(x: '&a) -> 'doc {
  let k = magic inspect-type(a);
  match k {
  | Algebraic(_, data-args, !cons-info) =>
    let data-arg-num = data-arg-count(data-args);
    let header = algebraic-header-slot-count(cons-info);
    quote {
      let discriminant-x = unquote {algebraic-discriminant(cons-info, x)};
      unquote {_algebraic-doc(cons-info, header, data-arg-num, quote {discriminant-x}, x)}
    }
  | Enum(names) =>
    quote {
      let discriminant-x = cast-inline<&a, int>(unquote {x});
      unquote {
        enum-switch(names, quote {discriminant-x}, quote {empty}, (name) => {
          quote {_constructor-doc(unquote {promote {name}})}
        })
      }
    }
  | Int1 =>
    quote {atom-int(magic cast(int1, int64, magic cast(&a, int1, unquote {x})))}
  | Int2 =>
    quote {atom-int(magic cast(int2, int64, magic cast(&a, int2, unquote {x})))}
  | Int4 =>
    quote {atom-int(magic cast(int4, int64, magic cast(&a, int4, unquote {x})))}
  | Int8 =>
    quote {atom-int(magic cast(int8, int64, magic cast(&a, int8, unquote {x})))}
  | Int16 =>
    quote {atom-int(magic cast(int16, int64, magic cast(&a, int16, unquote {x})))}
  | Int32 =>
    quote {atom-int(magic cast(int32, int64, magic cast(&a, int32, unquote {x})))}
  | Int64 =>
    quote {atom-int(magic cast(&a, int64, unquote {x}))}
  | Float16 =>
    quote {atom-float(magic cast(float16, float64, magic cast(&a, float16, unquote {x})))}
  | Float32 =>
    quote {atom(show-float32(magic cast(&a, float32, unquote {x})))}
  | Float64 =>
    quote {atom-float(magic cast(&a, float64, unquote {x}))}
  | Null =>
    quote {atom-N("null")}
  | Rune =>
    quote {
      _literal-doc(join[
        atom-N("`"),
        atom-rune(magic cast(&a, rune, unquote {x})),
        atom-N("`"),
      ])
    }
  | Binary =>
    quote {
      _literal-doc(join[
        atom-N("\""),
        atom-N(magic cast(&a, &string, unquote {x})),
        atom-N("\""),
      ])
    }
  | Wrapper(t) =>
    unpack-type t = t;
    quote {
      let x-unwrapped: &t = cast-inline<&a, &t>(unquote {x});
      unquote {to-doc<t>(quote {x-unwrapped})}
    }
  | Vector(t) =>
    unpack-type t = t;
    quote {
      let x: &vector(t) = cast-inline<&a, &vector(t)>(unquote {x});
      unquote {_vector-doc<t>(quote {x})}
    }
  | Noema(t) =>
    unpack-type t = t;
    quote {
      let x-unwrapped: &t = cast-inline<&a, &t>(unquote {x});
      unquote {to-doc<t>(quote {x-unwrapped})}
    }
  | Box-T(t) =>
    unpack-type t = t;
    quote {
      let x-unwrapped: &t = cast-inline<&a, &t>(unquote {x});
      unquote {to-doc<t>(quote {x-unwrapped})}
    }
  | Pointer =>
    quote {atom-int(magic cast(&a, int64, unquote {x}))}
  | _ =>
    quote {_literal-doc(atom-N("_"))}
  }
}

define-meta derive<a>(max-ribbon-width: 'int) -> 'show(a) {
  quote {
    Show{
      render := {
        (x) => {
          pin d = to-doc::(x);
          show-doc(d, unquote {max-ribbon-width})
        }
      },
    }
  }
}
