import {
  this.bool {bool},
  this.c-size {C-Size},
  this.control {discard},
  this.either {Right, none},
  this.int {max-int, min-int},
  this.list {Cons, Nil, fold-left-N, list},
  this.memory {malloc},
  this.memory.unsafe {free, load-int, load-int8, load-pointer, memcpy, store-int, store-int8, store-pointer},
  this.pointer {shift},
  this.unit {Unit, unit},
  this.unsafe {cast},
  this.word,
}

// int8-array
// internal representation: (head-index, last-index, content-pointer, byte-0, byte-1, ..., byte-n)
inline _content-pointer-offset() -> int {
  mul-int(this.word.size, 2)
}

inline _header-size() -> int {
  mul-int(this.word.size, 3)
}

inline _initialize-header(base-pointer: pointer, len: int) -> pointer {
  let content-pointer = shift(base-pointer, _header-size());
  store-int(0, base-pointer);
  store-int(len, shift(base-pointer, this.word.size));
  store-pointer(content-pointer, shift(base-pointer, _content-pointer-offset()));
  content-pointer
}

resource binary {
  (x: pointer, _: int) => {
    free(x)
  },
  (source-pointer: pointer, _: pointer) => {
    let u = this.word.size;
    let from = load-int(source-pointer);
    let to = load-int(shift(source-pointer, u));
    let length = sub-int(to, from);
    let target-pointer = malloc(C-Size(add-int(length, _header-size())));
    let target-content-pointer = _initialize-header(target-pointer, length);
    let source-content-pointer = load-pointer(shift(source-pointer, _content-pointer-offset()));
    memcpy(target-content-pointer, shift(source-content-pointer, from), length);
    target-pointer
  },
  -1,
}

inline from-blob(t: blob) -> &binary {
  magic cast(blob, &binary, t)
}

define length(xs: &binary) -> int {
  let source-pointer = magic cast(&binary, pointer, xs);
  let u = this.word.size;
  let from = load-int(source-pointer);
  let to = load-int(shift(source-pointer, u));
  sub-int(to, from)
}

inline with-slice<a>(xs: &binary, start: int, size: int, f: (&binary) -> +a) -> a {
  let ptr = cast<&binary, pointer>(xs);
  let u = this.word.size;
  let from = load-int(ptr);
  let to = load-int(shift(ptr, u));
  let len = sub-int(to, from);
  let start = min-int(max-int(start, 0), len);
  let size = min-int(max-int(size, 0), sub-int(len, start));
  let slice-from = add-int(from, start);
  let slice-to = add-int(slice-from, size);
  let content-ptr = load-pointer(shift(ptr, _content-pointer-offset()));
  let slice-ptr = magic alloca(int, 3);
  store-int(slice-from, slice-ptr);
  store-int(slice-to, shift(slice-ptr, u));
  store-pointer(content-ptr, shift(slice-ptr, _content-pointer-offset()));
  let slice = cast<pointer, &binary>(slice-ptr);
  letbox-T result = f(slice);
  result
}

define allocate(len: int) -> binary {
  let len = max-int(0, len);
  let base-pointer = malloc(C-Size(add-int(len, _header-size())));
  let content-pointer = _initialize-header(base-pointer, len);
  let store-values =
    define self(index: int) -> unit {
      if ge-int(index, len) {
        Unit
      } else {
        store-int8(0, shift(content-pointer, index));
        self(add-int(index, 1))
      }
    };
  store-values(0);
  cast<pointer, binary>(base-pointer)
}

define from-list(xs: list(int8)) -> binary {
  let len on xs = this.list.length(xs);
  let base-pointer = malloc(C-Size(add-int(len, _header-size())));
  let content-pointer = _initialize-header(base-pointer, len);
  let store-values =
    define self(values: list(int8), index: int) -> unit {
      match values {
      | Nil =>
        Unit
      | Cons(v, rest) =>
        store-int8(v, shift(content-pointer, index));
        self(rest, add-int(index, 1))
      }
    };
  store-values(xs, 0);
  cast<pointer, binary>(base-pointer)
}

inline _get-content-pointer(t: &binary) -> pointer {
  let ptr = cast<&binary, pointer>(t);
  let from = load-int(ptr);
  let content-pointer = load-pointer(shift(ptr, _content-pointer-offset()));
  shift(content-pointer, from)
}

inline _access(xs: &binary, i: int) -> int8 {
  load-int8(shift(_get-content-pointer(xs), i))
}

define replicate(t: &binary, n: int) -> binary {
  if le-int(n, 0) {
    allocate(0)
  } else {
    let base-len = length(t);
    let len = mul-int(n, base-len);
    let new-binary = malloc(C-Size(add-int(len, _header-size())));
    let content-ptr = _initialize-header(new-binary, len);
    let loop =
      define self(count: int, t: &binary) -> unit {
        if ge-int(count, n) {
          Unit
        } else {
          let current-content-ptr = shift(content-ptr, mul-int(count, base-len));
          let x-ptr = _get-content-pointer(t);
          memcpy(current-content-ptr, x-ptr, base-len);
          self(add-int(count, 1), t)
        }
      };
    loop(0, t);
    magic cast(pointer, binary, new-binary)
  }
}

define join(xs: list(binary)) -> binary {
  let len on xs =
    fold-left-N(0, xs, (acc, x) => {
      add-int(acc, length(x))
    });
  let new-binary = malloc(C-Size(add-int(len, _header-size())));
  let content-ptr = _initialize-header(new-binary, len);
  let loop =
    define self(offset: int, xs: list(binary)) -> unit {
      match xs {
      | Nil =>
        Unit
      | Cons(x, rest) =>
        let current-content-ptr = shift(content-ptr, offset);
        let x-ptr on x = _get-content-pointer(x);
        let x-len on x = length(x);
        memcpy(current-content-ptr, x-ptr, x-len);
        discard(x);
        self(add-int(offset, x-len), rest)
      }
    };
  loop(0, xs);
  magic cast(pointer, binary, new-binary)
}

define join-N(xs: &list(binary)) -> binary {
  let len =
    fold-left-N(0, xs, (acc, x) => {
      add-int(acc, length(x))
    });
  let new-binary = malloc(C-Size(add-int(len, _header-size())));
  let content-ptr = _initialize-header(new-binary, len);
  let loop =
    define self(offset: int, xs: &list(binary)) -> unit {
      case xs {
      | Nil =>
        Unit
      | Cons(x, rest) =>
        let current-content-ptr = shift(content-ptr, offset);
        let x-ptr = _get-content-pointer(x);
        let x-len = length(x);
        memcpy(current-content-ptr, x-ptr, x-len);
        self(add-int(offset, x-len), rest)
      }
    };
  loop(0, xs);
  magic cast(pointer, binary, new-binary)
}

define append(t1: &binary, t2: &binary) -> binary {
  let p1 = cast<&binary, pointer>(t1);
  let p2 = cast<&binary, pointer>(t2);
  let from1 = load-int(p1);
  let from2 = load-int(p2);
  let u = this.word.size;
  let to1 = load-int(shift(p1, u));
  let to2 = load-int(shift(p2, u));
  let len1 = sub-int(to1, from1);
  let len2 = sub-int(to2, from2);
  let new-len = add-int(len1, len2);
  let content1 = load-pointer(shift(p1, _content-pointer-offset()));
  let content2 = load-pointer(shift(p2, _content-pointer-offset()));
  let new-binary = malloc(C-Size(add-int(new-len, _header-size())));
  let str-pointer = _initialize-header(new-binary, new-len);
  let !store-values =
    define store-values(target-pointer: pointer, content-array: pointer, current-index: int, array-length: int) -> unit {
      if eq-int(current-index, array-length) {
        Unit
      } else {
        let char = load-int8(shift(content-array, current-index));
        store-int8(char, shift(target-pointer, current-index));
        store-values(target-pointer, content-array, add-int(current-index, 1), array-length)
      }
    };
  store-values(str-pointer, shift(content1, from1), 0, len1);
  store-values(shift(str-pointer, len1), shift(content2, from2), 0, len2);
  cast<pointer, binary>(new-binary)
}

// O(1)
define drop(t: binary, offset: int) -> binary {
  let offset = max-int(0, offset);
  let _ on t = {
    let ptr = cast<&binary, pointer>(t);
    let from = load-int(ptr);
    let to-ptr = shift(ptr, this.word.size);
    let to = load-int(to-ptr);
    store-int(min-int(to, add-int(from, offset)), ptr)
  };
  t
}

// O(1)
define take(t: binary, offset: int) -> binary {
  let offset = max-int(0, offset);
  let _ on t = {
    let ptr = cast<&binary, pointer>(t);
    let from = load-int(ptr);
    let to-ptr = shift(ptr, this.word.size);
    let to = load-int(to-ptr);
    store-int(min-int(to, add-int(from, offset)), to-ptr)
  };
  t
}

// O(1)
define slice(t: binary, start: int, size: int) -> binary {
  take(drop(t, start), size)
}

define drop-N(t: &binary, offset: int) -> binary {
  let content-ptr = _get-content-pointer(t);
  let orig-size = length(t);
  let offset = min-int(max-int(0, offset), orig-size);
  let new-size = sub-int(orig-size, offset);
  let new-ptr = malloc(C-Size(add-int(new-size, _header-size())));
  let new-content-ptr = _initialize-header(new-ptr, new-size);
  let content-ptr = shift(content-ptr, offset);
  memcpy(new-content-ptr, content-ptr, new-size);
  cast<pointer, binary>(new-ptr)
}

define take-N(t: &binary, offset: int) -> binary {
  let len = length(t);
  let new-size = min-int(max-int(0, offset), len);
  let new-ptr = malloc(C-Size(add-int(new-size, _header-size())));
  let new-content-ptr = _initialize-header(new-ptr, new-size);
  let content-ptr = _get-content-pointer(t);
  memcpy(new-content-ptr, content-ptr, new-size);
  cast<pointer, binary>(new-ptr)
}

define slice-N(t: &binary, start: int, size: int) -> binary {
  let len = length(t);
  let start = min-int(max-int(start, 0), len);
  let size = max-int(size, 0);
  let new-size = min-int(size, sub-int(len, start));
  let content-ptr = _get-content-pointer(t);
  let new-ptr = malloc(C-Size(add-int(new-size, _header-size())));
  let new-content-ptr = _initialize-header(new-ptr, new-size);
  memcpy(new-content-ptr, shift(content-ptr, start), new-size);
  cast<pointer, binary>(new-ptr)
}

define take-end(t: binary, offset: int) -> binary {
  let len on t = length(t);
  drop(t, sub-int(len, offset))
}

define take-end-N(t: &binary, offset: int) -> binary {
  let len = length(t);
  drop-N(t, sub-int(len, offset))
}

define drop-end(t: binary, offset: int) -> binary {
  let len on t = length(t);
  take(t, sub-int(len, offset))
}

define drop-end-N(t: &binary, offset: int) -> binary {
  let len = length(t);
  take-N(t, sub-int(len, offset))
}

define intercalate(xs: list(binary), sep: binary) -> binary {
  join(this.list.intercalate(xs, sep))
}

define intercalate-N(xs: &list(binary), sep: &binary) -> binary {
  let base-len =
    fold-left-N(0, xs, (acc, x) => {
      add-int(acc, length(x))
    });
  let xs-len = this.list.length(xs);
  let sep-num = max-int(0, sub-int(xs-len, 1));
  let len = add-int(base-len, mul-int(length(sep), sep-num));
  let new-binary = malloc(C-Size(add-int(len, _header-size())));
  let content-ptr = _initialize-header(new-binary, len);
  let loop =
    define self(offset: int, xs: &list(binary)) -> unit {
      case xs {
      | Nil =>
        Unit
      | Cons(x, rest) =>
        let current-content-ptr = shift(content-ptr, offset);
        let x-ptr = _get-content-pointer(x);
        let x-len = length(x);
        memcpy(current-content-ptr, x-ptr, x-len);
        let new-offset = add-int(offset, x-len);
        case rest {
        | Nil =>
          self(new-offset, rest)
        | Cons(_, _) =>
          let current-content-ptr = shift(content-ptr, new-offset);
          let sep-ptr = _get-content-pointer(sep);
          let sep-len = length(sep);
          memcpy(current-content-ptr, sep-ptr, sep-len);
          self(add-int(new-offset, sep-len), rest)
        };
      }
    };
  loop(0, xs);
  magic cast(pointer, binary, new-binary)
}

define find(xs: &binary, !pred: (int8) -> bool) ->> ?int {
  let len = length(xs);
  let f =
    define self(index: int) ->> ?int {
      if ge-int(index, len) {
        none
      } else {
        let ch = _access(xs, index);
        if pred(ch) {
          Right(index)
        } else {
          self(add-int(index, 1))
        }
      }
    };
  f(0)
}

define find-end(xs: &binary, !pred: (int8) -> bool) ->> ?int {
  let len = length(xs);
  let f =
    define self(xs: &binary, index: int) ->> ?int {
      if lt-int(index, 0) {
        none
      } else {
        let ch = _access(xs, index);
        if pred(ch) {
          Right(sub-int(len, add-int(index, 1)))
        } else {
          self(xs, sub-int(index, 1))
        }
      }
    };
  f(xs, sub-int(len, 1))
}

define _get-matched-prefix-length(xs: &binary, ys: &binary, cursor: int, len: int) -> int {
  if ge-int(cursor, len) {
    cursor
  } else {
    let x = _access(xs, cursor);
    let y = _access(ys, cursor);
    if eq-int8(x, y) {
      _get-matched-prefix-length(xs, ys, add-int(cursor, 1), len)
    } else {
      0
    }
  }
}

define strip-prefix(prefix: &binary, haystack: binary) -> binary {
  let len-prefix = length(prefix);
  let len-haystack on haystack = length(haystack);
  if gt-int(len-prefix, len-haystack) {
    haystack
  } else {
    let matched-length on haystack = _get-matched-prefix-length(prefix, haystack, 0, len-prefix);
    drop(haystack, matched-length)
  }
}

define _get-matched-suffix-length(xs: &binary, ys: &binary, x-cursor: int, y-cursor: int, len: int) -> int {
  if lt-int(x-cursor, 0) {
    len
  } else-if lt-int(y-cursor, 0) {
    len
  } else {
    let x = _access(xs, x-cursor);
    let y = _access(ys, y-cursor);
    if eq-int8(x, y) {
      _get-matched-suffix-length(xs, ys, sub-int(x-cursor, 1), sub-int(y-cursor, 1), len)
    } else {
      0
    }
  }
}

define strip-suffix(suffix: &binary, haystack: binary) -> binary {
  let len-suffix = length(suffix);
  let len-haystack on haystack = length(haystack);
  if gt-int(len-suffix, len-haystack) {
    haystack
  } else {
    let matched-length on haystack =
      _get-matched-suffix-length(
        suffix,
        haystack,
        sub-int(len-suffix, 1),
        sub-int(len-haystack, 1),
        len-suffix,
      );
    drop-end(haystack, matched-length)
  }
}
