import {
  this.binary {binary},
  this.binary.io,
  this.bool,
  this.either {Left, Right},
  this.file.descriptor {descriptor, stdin, stdout},
  this.string {byte-length, string, to-binary},
  this.string.pointer {get-content-pointer},
  this.system {report-system-error, system},
  this.unit {Unit, unit},
  this.unsafe {cast},
}

foreign {
  neut_core_v0_55_write_line(descriptor, int, pointer) -> int,
}

define write(f: descriptor, t: &string) ->> system(unit) {
  this.binary.io.write(f, to-binary(t))
}

define write-line(d: descriptor, t: &string) ->> system(unit) {
  let len = byte-length(t);
  let ptr = get-content-pointer(t);
  let result = magic external neut_core_v0_55_write_line(d, len, ptr);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define print(t: &string) -> unit {
  match write(stdout, t) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define print-line(t: &string) -> unit {
  match write-line(stdout, t) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define read(from: descriptor, initial-buffer-size: int) ->> system(string) {
  try bin = this.binary.io.read(from, initial-buffer-size);
  Right(cast<binary, string>(bin))
}

define read-stdin(initial-buffer-size: int) ->> system(string) {
  read(stdin, initial-buffer-size)
}
