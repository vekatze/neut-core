import {
  this.bool,
  this.either {Right},
  this.file.descriptor {descriptor, stdout},
  this.system {report-system-error, system},
  this.unit {Unit, unit},
}

foreign {
  neut_core_v0_55_write_int64(descriptor, int64) -> int,
  neut_core_v0_55_write_int64_nl(descriptor, int64) -> int,
}

define write-int(d: descriptor, x: int) ->> system(unit) {
  let result = magic external neut_core_v0_55_write_int64(d, x);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define write-int-line(d: descriptor, x: int) ->> system(unit) {
  let result = magic external neut_core_v0_55_write_int64_nl(d, x);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define print-int(x: int) -> unit {
  let _ = write-int(stdout, x);
  Unit
}

define print-int-line(x: int) -> unit {
  let _ = write-int-line(stdout, x);
  Unit
}
