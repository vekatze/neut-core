import {
  this.list {Cons, Nil, list},
  this.ord {Ord, ord},
  this.ordering {EQ, GT, LT, ordering},
}

inline as-ord<a>(!o: ord(a)) -> ord(list(a)) {
  let Ord{compare := !compare} = o;
  Ord{
    compare := {
      define self(xs: &list(a), ys: &list(a)) -> ordering {
        case xs, ys {
        | Nil, Nil =>
          EQ
        | Nil, Cons(_, _) =>
          LT
        | Cons(_, _), Nil =>
          GT
        | Cons(x, xs), Cons(y, ys) =>
          match compare(x, y) {
          | LT =>
            LT
          | GT =>
            GT
          | EQ =>
            self(xs, ys)
          }
        }
      }
    },
  }
}
