import {
  this.binary.eq {eq-binary, ne-binary},
  this.bool {bool},
  this.eq {Eq, eq},
  this.string {_String, string},
}

define eq-string(t1: &string, t2: &string) -> bool {
  tie _String(xs1) = t1;
  tie _String(xs2) = t2;
  eq-binary(xs1, xs2)
}

define ne-string(t1: &string, t2: &string) -> bool {
  tie _String(xs1) = t1;
  tie _String(xs2) = t2;
  ne-binary(xs1, xs2)
}

constant as-eq: eq(string) {
  Eq{equal := eq-string}
}

define eq-prefix(haystack: &string, needle: &string) -> bool {
  tie _String(haystack) = haystack;
  tie _String(needle) = needle;
  this.binary.eq.eq-prefix(haystack, needle)
}

define eq-suffix(haystack: &string, needle: &string) -> bool {
  tie _String(haystack) = haystack;
  tie _String(needle) = needle;
  this.binary.eq.eq-suffix(haystack, needle)
}

define eq-infix(haystack: &string, needle: &string) -> bool {
  tie _String(haystack) = haystack;
  tie _String(needle) = needle;
  this.binary.eq.eq-infix(haystack, needle)
}
