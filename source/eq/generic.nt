import {
  this.binary {binary},
  this.binary.eq {eq-binary},
  this.bool {False, True, bool},
  this.either {Left, Right},
  this.eq {Eq, eq},
  this.list {Cons, Nil, list},
  this.memory.unsafe {load-int, load-pointer},
  this.pair {Pair, pair},
  this.pointer {shift},
  this.rune.eq {eq-rune},
  this.string {string},
  this.type-value {
    Algebraic,
    Binary,
    Constructor,
    Enum,
    Float16,
    Float32,
    Float64,
    Int1,
    Int16,
    Int2,
    Int32,
    Int4,
    Int64,
    Int8,
    Rune,
    Vector,
    Wrapper,
    constructor,
  },
  this.unsafe {cast},
  this.vector {vector},
  this.word,
}

inline-meta _meta-length<a>(xs: list(a)) -> int {
  match xs {
  | Nil =>
    0
  | Cons(_, ys) =>
    add-int(1, _meta-length(ys))
  }
}

inline-meta _meta-for-each<a, b>(xs: list(a), !f: (a) -> b) -> list(b) {
  match xs {
  | Nil =>
    Nil
  | Cons(y, ys) =>
    Cons(f(y), _meta-for-each(ys, f))
  }
}

inline-meta _meta-snd<a, b>(p: pair(a, b)) -> b {
  let Pair(_, y) = p;
  y
}

inline-meta _join-string(t1: &string, t2: &string) -> &string {
  let tmp = magic string-uncons(t1);
  match tmp {
  | Left(_) =>
    t2
  | Right(Pair(r, rest)) =>
    magic string-cons(r, _join-string(rest, t2))
  }
}

nominal {
  define-meta eq-data<a>(x: '&a, y: '&a) -> 'bool,
}

inline-meta _equal-vector<a>(xs: '&vector(a), ys: '&vector(a)) -> 'bool {
  quote {
    let len-x = this.vector.length(unquote {xs});
    let len-y = this.vector.length(unquote {ys});
    if eq-int(len-x, len-y) {
      this.vector.zip-fold(unquote {xs}, unquote {ys}, True, (x: &a, y: &a, acc: bool, _: int) => {
        if acc {
          unquote {eq-data(quote {x}, quote {y})}
        } else {
          False
        }
      })
    } else {
      False
    }
  }
}

inline _load-nth-element(header: int, data-arg-num: int, cursor: int, x: pointer) -> pointer {
  let u = this.word.size;
  let offset = mul-int(u, add-int(header, add-int(data-arg-num, cursor))); // x = (disc?, data-args, cons-args)
  let elem-ptr = shift(x, offset);
  load-pointer(elem-ptr)
}

inline-meta _eq-data-adt-cons<a>(
  cons-arg-types: list(type),
  data-arg-num: int,
  header: int,
  cursor: int,
  x: '&a,
  y: '&a,
) -> 'bool {
  match cons-arg-types {
  | Nil =>
    quote {True}
  | Cons(t, rest) =>
    unpack-type t = t;
    quote {
      let header-inner = unquote {promote {header}};
      let data-arg-num-inner = unquote {promote {data-arg-num}};
      let low-cursor = unquote {promote {cursor}};
      let x-ptr = cast<&a, pointer>(unquote {x});
      let y-ptr = cast<&a, pointer>(unquote {y});
      let x-elem-ptr = cast<pointer, &t>(_load-nth-element(header-inner, data-arg-num-inner, low-cursor, x-ptr));
      let y-elem-ptr = cast<pointer, &t>(_load-nth-element(header-inner, data-arg-num-inner, low-cursor, y-ptr));
      let is-eq = unquote {eq-data(quote {x-elem-ptr}, quote {y-elem-ptr})};
      if is-eq {
        unquote {_eq-data-adt-cons(rest, data-arg-num, header, add-int(cursor, 1), x, y)}
      } else {
        False
      }
    }
  }
}

inline-meta _eq-data-adt<a>(
  constructors: list(constructor),
  cons-index: int,
  data-arg-num: int,
  disc: 'int,
  x: '&a,
  y: '&a,
) -> 'bool {
  match constructors {
  | Nil =>
    quote {True}
  | Cons(Constructor(_, _, xts), rest) =>
    let ts = _meta-for-each(xts, exact _meta-snd);
    quote {
      if eq-int(unquote {promote {cons-index}}, unquote {disc}) {
        unquote {_eq-data-adt-cons(ts, data-arg-num, 1, 0, x, y)}
      } else {
        unquote {_eq-data-adt(rest, add-int(cons-index, 1), data-arg-num, disc, x, y)}
      }
    }
  }
}

inline-meta _eq-data-single-cons<a>(
  constructors: list(constructor),
  data-arg-num: int,
  x: '&a,
  y: '&a,
) -> 'bool {
  match constructors {
  | Nil =>
    quote {True}
  | Cons(Constructor(_, _, xts), _) =>
    let ts = _meta-for-each(xts, exact _meta-snd);
    _eq-data-adt-cons(ts, data-arg-num, 0, 0, x, y)
  }
}

define-meta eq-data<a>(x: '&a, y: '&a) -> 'bool {
  let k = magic inspect-type(a);
  match k {
  | Algebraic(_, data-args, !cons-info) =>
    let data-arg-num = _meta-length(data-args);
    if gt-int(_meta-length(cons-info), 1) {
      quote {
        let ptr-x = cast<&a, pointer>(unquote {x});
        let ptr-y = cast<&a, pointer>(unquote {y});
        let discriminant-x = load-int(ptr-x);
        let discriminant-y = load-int(ptr-y);
        if ne-int(discriminant-x, discriminant-y) {
          False
        } else {
          unquote {_eq-data-adt(cons-info, 0, data-arg-num, quote {discriminant-x}, x, y)}
        }
      }
    } else {
      _eq-data-single-cons(cons-info, data-arg-num, x, y)
    }
  | Enum(_) =>
    quote {
      let discriminant-x = cast<&a, int>(unquote {x});
      let discriminant-y = cast<&a, int>(unquote {y});
      eq-int(discriminant-x, discriminant-y)
    }
  | Int1 =>
    quote {
      let x = cast<&a, int1>(unquote {x});
      let y = cast<&a, int1>(unquote {y});
      eq-int1(x, y)
    }
  | Int2 =>
    quote {
      let x = cast<&a, int2>(unquote {x});
      let y = cast<&a, int2>(unquote {y});
      eq-int2(x, y)
    }
  | Int4 =>
    quote {
      let x = cast<&a, int4>(unquote {x});
      let y = cast<&a, int4>(unquote {y});
      eq-int4(x, y)
    }
  | Int8 =>
    quote {
      let x = cast<&a, int8>(unquote {x});
      let y = cast<&a, int8>(unquote {y});
      eq-int8(x, y)
    }
  | Int16 =>
    quote {
      let x = cast<&a, int16>(unquote {x});
      let y = cast<&a, int16>(unquote {y});
      eq-int16(x, y)
    }
  | Int32 =>
    quote {
      let x = cast<&a, int32>(unquote {x});
      let y = cast<&a, int32>(unquote {y});
      eq-int32(x, y)
    }
  | Int64 =>
    quote {
      let x = cast<&a, int64>(unquote {x});
      let y = cast<&a, int64>(unquote {y});
      eq-int64(x, y)
    }
  | Float16 =>
    quote {
      let x = cast<&a, float16>(unquote {x});
      let y = cast<&a, float16>(unquote {y});
      eq-float16(x, y)
    }
  | Float32 =>
    quote {
      let x = cast<&a, float32>(unquote {x});
      let y = cast<&a, float32>(unquote {y});
      eq-float32(x, y)
    }
  | Float64 =>
    quote {
      let x = cast<&a, float64>(unquote {x});
      let y = cast<&a, float64>(unquote {y});
      eq-float64(x, y)
    }
  | Rune =>
    quote {
      let x = cast<&a, rune>(unquote {x});
      let y = cast<&a, rune>(unquote {y});
      eq-rune(x, y)
    }
  | Binary =>
    quote {
      let x = cast<&a, &binary>(unquote {x});
      let y = cast<&a, &binary>(unquote {y});
      eq-binary(x, y)
    }
  | Vector(t) =>
    unpack-type t = t;
    quote {
      let x: &vector(t) = cast<&a, &vector(t)>(unquote {x});
      let y: &vector(t) = cast<&a, &vector(t)>(unquote {y});
      unquote {_equal-vector<t>(quote {x}, quote {y})}
    }
  | Wrapper(t) =>
    unpack-type t = t;
    quote {
      let x: &t = cast<&a, &t>(unquote {x});
      let y: &t = cast<&a, &t>(unquote {y});
      unquote {eq-data(quote {x}, quote {y})}
    }
  | _ =>
    let t = magic show-type(a);
    let message = _join-string("eq-data doesn't support: ", t);
    magic compile-error(message)
  }
}

define-meta derive<a>() -> 'eq(a) {
  quote {
    Eq{
      equal := {
        (x, y) => {
          eq-data::(x, y)
        }
      },
    }
  }
}
