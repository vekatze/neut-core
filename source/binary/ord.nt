import {
  this.binary {_get-content-pointer, binary, binary-length},
  this.bool {False, True, bool},
  this.c-size {C-Size, c-size},
  this.int {min-int},
  this.ord {Ord, ord},
  this.ordering {EQ, GT, LT, ordering},
}

foreign {
  memcmp(pointer, pointer, c-size) -> int,
}

define _cmp-binary(ptr1: pointer, ptr2: pointer, len: int, fallback: ordering) -> ordering {
  let result = magic external memcmp(ptr1, ptr2, C-Size(len));
  if gt-int(result, 0) {
    GT
  } else-if lt-int(result, 0) {
    LT
  } else {
    fallback
  }
}

inline cmp-binary(xs1: &binary, xs2: &binary) -> ordering {
  let ptr1 = _get-content-pointer(xs1);
  let ptr2 = _get-content-pointer(xs2);
  let len1 = binary-length(xs1);
  let len2 = binary-length(xs2);
  let len = min-int(len1, len2);
  let fallback =
    if gt-int(len1, len2) {
      GT
    } else-if lt-int(len1, len2) {
      LT
    } else {
      EQ
    };
  _cmp-binary(ptr1, ptr2, len, fallback)
}

define lt-binary(t1: &binary, t2: &binary) -> bool {
  match cmp-binary(t1, t2) {
  | LT =>
    True
  | _ =>
    False
  }
}

define le-binary(t1: &binary, t2: &binary) -> bool {
  match cmp-binary(t1, t2) {
  | GT =>
    False
  | _ =>
    True
  }
}

define gt-binary(t1: &binary, t2: &binary) -> bool {
  match cmp-binary(t1, t2) {
  | GT =>
    True
  | _ =>
    False
  }
}

define ge-binary(t1: &binary, t2: &binary) -> bool {
  match cmp-binary(t1, t2) {
  | LT =>
    False
  | _ =>
    True
  }
}

constant as-ord: ord(binary) {
  Ord{
    compare := {
      (x, y) => {
        cmp-binary(x, y)
      }
    },
  }
}
