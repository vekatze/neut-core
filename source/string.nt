import {
  this.binary {_copy-binary, binary, binary-access, binary-length, binary-new},
  this.bool {False, True, bool},
  this.box,
  this.c-size {C-Size, c-size},
  this.either {Right, none},
  this.external {malloc},
  this.list {Cons, List, Nil, list, reverse},
  this.magic,
  this.memory {load-int, load-int8, store-int},
  this.pair {Pair, pair},
  this.pointer {shift},
  this.rune {load-rune, size-by-head-byte, store-rune, to-int32},
  this.text {text},
  this.unit {Unit, unit},
  this.word,
}

data string {
| _String(content: binary)
}

define create(xs: list(int8)) -> string {
  magic cast(binary, string, binary-new(xs))
}

define empty() -> string {
  create(Nil)
}

inline from-text(t: text) -> &string {
  magic cast(text, &string, t)
}

inline to-binary(x: &string) -> &binary {
  tie _String(content) = x;
  content
}

inline string-byte-length(t: &string) -> int {
  let ptr = magic cast(&string, &binary, t);
  binary-length(ptr)
}

define _get-content-pointer(t: &string) -> pointer {
  let ptr = this.magic.cast<&string, pointer>(t);
  let from = load-int(ptr);
  let u = this.word.size;
  shift(ptr, add-int(mul-int(u, 2), from))
}

define join(xs: list(string)) -> string {
  let xs = magic cast(list(string), list(binary), xs);
  _String(this.binary.join(xs))
}

define join-N(xs: &list(string)) -> string {
  let xs = magic cast(&list(string), &list(binary), xs);
  _String(this.binary.join-N(xs))
}

define append(t1: &string, t2: &string) -> string {
  tie _String(t1) = t1;
  tie _String(t2) = t2;
  _String(this.binary.append(t1, t2))
}

define _access(haystack: &string, cursor: int) -> int8 {
  binary-access(magic cast(&string, &binary, haystack), cursor)
}

define is-empty(t: &string) -> bool {
  eq-int(string-byte-length(t), 0)
}

// O(1)
define _drop(t: string, offset: int) -> string {
  let t = magic cast(string, binary, t);
  magic cast(binary, string, this.binary.drop(t, offset))
}

// O(1)
define _take(t: string, offset: int) -> string {
  let t = magic cast(string, binary, t);
  magic cast(binary, string, this.binary.take(t, offset))
}

// O(1)
define _slice(t: string, start: int, size: int) -> string {
  let t = magic cast(string, binary, t);
  magic cast(binary, string, this.binary.slice(t, start, size))
}

define _drop-N(t: &string, offset: int) -> string {
  let t = magic cast(&string, &binary, t);
  magic cast(binary, string, this.binary.drop-N(t, offset))
}

define _take-N(t: &string, offset: int) -> string {
  let t = magic cast(&string, &binary, t);
  magic cast(binary, string, this.binary.take-N(t, offset))
}

define _slice-N(t: &string, start: int, size: int) -> string {
  let t = magic cast(&string, &binary, t);
  magic cast(binary, string, this.binary.slice-N(t, start, size))
}

foreign {
  memcmp(pointer, pointer, c-size): int,
}

define _match-string-content(ptr1: pointer, ptr2: pointer, len: int) -> bool {
  let result = magic external memcmp(ptr1, ptr2, C-Size(len));
  eq-int(result, 0)
}

define break(haystack: &string, needle: &string) -> pair(string, string) {
  let ptr = _get-content-pointer(haystack);
  let ptr2 = _get-content-pointer(needle);
  let len = string-byte-length(haystack);
  let needle-len = string-byte-length(needle);
  let f =
    define loop(cursor: int) -> pair(string, string) {
      let rem-len = sub-int(len, cursor);
      if lt-int(rem-len, needle-len) {
        Pair(*haystack, empty())
      } else {
        let ptr1 = shift(ptr, cursor);
        if _match-string-content(ptr1, ptr2, needle-len) {
          let former = _take-N(haystack, cursor);
          let latter = _drop-N(haystack, cursor);
          Pair(former, latter)
        } else {
          loop(add-int(cursor, 1))
        }
      }
    };
  f(0)
}

define find-string(haystack: &string, needle: &string) -> bool {
  let ptr = _get-content-pointer(haystack);
  let ptr2 = _get-content-pointer(needle);
  let len = string-byte-length(haystack);
  let needle-len = string-byte-length(needle);
  let f =
    define loop(cursor: int) -> bool {
      let rem-len = sub-int(len, cursor);
      if lt-int(rem-len, needle-len) {
        False
      } else {
        let ptr1 = shift(ptr, cursor);
        if _match-string-content(ptr1, ptr2, needle-len) {
          True
        } else {
          loop(add-int(cursor, 1))
        }
      }
    };
  f(0)
}

define intercalate(xs: list(string), sep: string) -> string {
  join(this.list.intercalate(xs, sep))
}

define intercalate-N(xs: &list(string), sep: &string) -> string {
  let xs = magic cast(&list(string), &list(binary), xs);
  _String(this.binary.intercalate-N(xs, to-binary(sep)))
}

define _get-byte(t: &string, index: int) -> int8 {
  let ptr = _get-content-pointer(t);
  load-int8(shift(ptr, index))
}

define _get-rune-size(t: &string, index: int) -> int {
  let head-byte = _get-byte(t, index);
  size-by-head-byte(head-byte)
}

define _get-rune-size-end(t: &string, index: int) -> int {
  let b0 = _get-byte(t, index);
  if ult-int8(b0, 0x80) {
    1
  } else {
    let b1 = _get-byte(t, sub-int(index, 1));
    if uge-int8(b1, 0xc0) {
      2
    } else {
      let b2 = _get-byte(t, sub-int(index, 2));
      if uge-int8(b2, 0xc0) {
        3
      } else {
        4
      }
    }
  }
}

define singleton(value: rune) -> string {
  let s = this.rune.size(value);
  let value = to-int32(value);
  match s {
  | 1 =>
    let piece-0 = trunc-int32-int8(value);
    create(List[piece-0])
  | 2 =>
    let piece-0 = trunc-int32-int8(lshr-int32(and-int32(0b_1111_1111_0000_0000, value), 8));
    let piece-1 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_1111_1111, value), 0));
    create(List[piece-0, piece-1])
  | 3 =>
    let piece-0 = trunc-int32-int8(lshr-int32(and-int32(0b_1111_1111_0000_0000_0000_0000, value), 16));
    let piece-1 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_1111_1111_0000_0000, value), 8));
    let piece-2 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_0000_0000_1111_1111, value), 0));
    create(List[piece-0, piece-1, piece-2])
  | 4 =>
    let piece-0 = trunc-int32-int8(lshr-int32(and-int32(0b_1111_1111_0000_0000_0000_0000_0000_0000, value), 24));
    let piece-1 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_1111_1111_0000_0000_0000_0000, value), 16));
    let piece-2 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_0000_0000_1111_1111_0000_0000, value), 8));
    let piece-3 = trunc-int32-int8(lshr-int32(and-int32(0b_0000_0000_0000_0000_0000_0000_1111_1111, value), 0));
    create(List[piece-0, piece-1, piece-2, piece-3])
  | _ =>
    // U+FFFE Noncharacter
    create(List[0xef, 0xbf, 0xbe])
  }
}

define _length(t: &string, len: int, index: int, acc: int) -> int {
  if ge-int(index, len) {
    acc
  } else {
    let rune-size = _get-rune-size(t, index);
    _length(t, len, add-int(index, rune-size), add-int(acc, 1))
  }
}

define length(t: &string) -> int {
  let len = string-byte-length(t);
  _length(t, len, 0, 0)
}

define split(haystack: &string, needle: &string) -> list(string) {
  let haystack-ptr = _get-content-pointer(haystack);
  let needle-ptr = _get-content-pointer(needle);
  let len = string-byte-length(haystack);
  let needle-len = string-byte-length(needle);
  let f =
    define loop(pivot: int, cursor: int) -> list(string) {
      let rem-len = sub-int(len, add-int(pivot, cursor));
      if lt-int(rem-len, needle-len) {
        List[_drop-N(haystack, pivot)]
      } else {
        let current-ptr = shift(haystack-ptr, add-int(pivot, cursor));
        if _match-string-content(current-ptr, needle-ptr, needle-len) {
          let piece = _slice-N(haystack, pivot, cursor);
          let next-pivot = add-int(pivot, add-int(cursor, needle-len));
          let rest = loop(next-pivot, 0);
          Cons(piece, rest)
        } else {
          loop(pivot, add-int(cursor, 1))
        }
      }
    };
  if eq-int(needle-len, 0) {
    Nil
  } else {
    f(0, 0)
  }
}

define lines(haystack: &string) -> list(string) {
  split(haystack, "\n")
}

define unlines(xs: &list(string)) -> string {
  intercalate-N(xs, "\n")
}

define replace(haystack: &string, from: &string, to: string) -> string {
  this.string.intercalate(split(haystack, from), to)
}

// [x1], [y1, y2] => [x1]
// [x1, x2], [y1, y2, y3] => [x1, y1, x2]
// [x1, x2, x3], [y1, y2] => [x1, y1, x2, y2, x3]
define _alternate<a>(xs: list(a), ys: list(a)) -> list(a) {
  match xs, ys {
  | Nil, _ =>
    Nil
  | Cons(x, Nil), _ =>
    Cons(x, Nil)
  | Cons(x1, Cons(x2, xs)), Nil =>
    Cons(x1, Cons(x2, xs))
  | Cons(x1, Cons(x2, xs)), Cons(y, ys) =>
    Cons(x1, Cons(y, _alternate(Cons(x2, xs), ys)))
  }
}

define _format(fmt: &string, args: list(string)) -> list(string) {
  _alternate(split(fmt, "{}"), args)
}

define format(fmt: &string, args: list(string)) -> string {
  join(_format(fmt, args))
}

define _unpack(ptr: pointer, len: int, index: int, acc: list(rune)) -> list(rune) {
  if ge-int(index, len) {
    reverse(acc)
  } else {
    let r = load-rune(shift(ptr, index));
    let s = this.rune.size(r);
    _unpack(ptr, len, add-int(index, s), Cons(r, acc))
  }
}

define unpack(t: &string) -> list(rune) {
  let ptr = _get-content-pointer(t);
  let len = string-byte-length(t);
  _unpack(ptr, len, 0, Nil)
}

define _char-list-length(xs: &list(rune), acc: int) -> int {
  case xs {
  | Nil =>
    acc
  | Cons(x, rest) =>
    _char-list-length(rest, add-int(acc, this.rune.size(*x)))
  }
}

define pack(xs: &list(rune)) -> string {
  let len = _char-list-length(xs, 0);
  let u = this.word.size;
  let u2 = mul-int(u, 2);
  let new-string = malloc(C-Size(add-int(len, u2)));
  store-int(0, new-string);
  store-int(len, shift(new-string, u));
  let content-ptr = shift(new-string, u2);
  let loop =
    define self(offset: int, xs: &list(rune)) -> unit {
      case xs {
      | Nil =>
        Unit
      | Cons(x, rest) =>
        let current-content-ptr = shift(content-ptr, offset);
        let stored-bytes = store-rune(*x, current-content-ptr);
        self(add-int(offset, stored-bytes), rest)
      }
    };
  loop(0, xs);
  magic cast(pointer, string, new-string)
}

define reverse(t: &string) -> string {
  // for now
  pin xs = this.list.reverse(unpack(t));
  pack(xs)
}

define _get-rune(t: &string, index: int) -> rune {
  let ptr = shift(_get-content-pointer(t), index);
  load-rune(ptr)
}

define get-first-rune(t: &string) ->> ?rune {
  if gt-int(string-byte-length(t), 0) {
    Right(_get-rune(t, 0))
  } else {
    none
  }
}

define uncons(t: string) ->> ?pair(rune, string) {
  let len on t = string-byte-length(t);
  if eq-int(len, 0) {
    none
  } else {
    let ch on t = _get-rune(t, 0);
    let char-len = this.rune.size(ch);
    let t = _drop(t, char-len);
    Right(Pair(ch, t))
  }
}

define _find-pivot(char-len: int, len: int, t: &string, index: int, char-count: int) -> int {
  if ge-int(index, len) {
    index
  } else-if ge-int(char-count, char-len) {
    index
  } else {
    let char-size = _get-rune-size(t, index);
    _find-pivot(char-len, len, t, add-int(index, char-size), add-int(char-count, 1))
  }
}

define _find-pivot-end(char-len: int, len: int, t: &string, index: int, char-count: int) -> int {
  if lt-int(index, 0) {
    0
  } else-if ge-int(char-count, char-len) {
    add-int(index, 1)
  } else {
    let rune-size = _get-rune-size-end(t, index);
    _find-pivot-end(char-len, len, t, sub-int(index, rune-size), add-int(char-count, 1))
  }
}

define take(t: string, n: int) -> string {
  let len on t = string-byte-length(t);
  let pivot on t = _find-pivot(n, len, t, 0, 0);
  _take(t, pivot)
}

define take-N(t: &string, n: int) -> string {
  let len = string-byte-length(t);
  let pivot = _find-pivot(n, len, t, 0, 0);
  _take-N(t, pivot)
}

define drop(t: string, n: int) -> string {
  let len on t = string-byte-length(t);
  let pivot on t = _find-pivot(n, len, t, 0, 0);
  _drop(t, pivot)
}

define drop-N(t: &string, n: int) -> string {
  let len = string-byte-length(t);
  let pivot = _find-pivot(n, len, t, 0, 0);
  _drop-N(t, pivot)
}

define take-end(t: string, n: int) -> string {
  let len on t = string-byte-length(t);
  let pivot on t = _find-pivot-end(n, len, t, sub-int(len, 1), 0);
  _drop(t, pivot)
}

define take-end-N(t: &string, n: int) -> string {
  let len = string-byte-length(t);
  let pivot = _find-pivot-end(n, len, t, sub-int(len, 1), 0);
  _drop-N(t, pivot)
}

define drop-end(t: string, n: int) -> string {
  let len on t = string-byte-length(t);
  let pivot on t = _find-pivot-end(n, len, t, sub-int(len, 1), 0);
  _take(t, pivot)
}

define drop-end-N(t: &string, n: int) -> string {
  let len = string-byte-length(t);
  let pivot = _find-pivot-end(n, len, t, sub-int(len, 1), 0);
  _take-N(t, pivot)
}

define slice(t: string, start: int, size: int) -> string {
  let len on t = string-byte-length(t);
  let start-byte-index on t = _find-pivot(start, len, t, 0, 0);
  let end-byte-index on t = _find-pivot(size, len, t, start-byte-index, 0);
  _slice(t, start-byte-index, sub-int(end-byte-index, start-byte-index))
}

define slice-N(t: &string, start: int, size: int) -> string {
  let len = string-byte-length(t);
  let start-byte-index = _find-pivot(start, len, t, 0, 0);
  let end-byte-index = _find-pivot(size, len, t, start-byte-index, 0);
  _slice-N(t, start-byte-index, sub-int(end-byte-index, start-byte-index))
}

inline take-while(t: string, !pred: (rune) -> bool) -> string {
  let f =
    define self(t: string, index: int) -> string {
      let len on t = string-byte-length(t);
      if ge-int(index, len) {
        take(t, index)
      } else {
        let ch on t = _get-rune(t, index);
        if pred(ch) {
          let char-len = this.rune.size(ch);
          self(t, add-int(index, char-len))
        } else {
          take(t, index)
        }
      }
    };
  f(t, 0)
}

inline take-while-N(t: &string, !pred: (rune) -> bool) -> string {
  let len = string-byte-length(t);
  let f =
    define self(index: int, acc: list(rune)) -> list(rune) {
      if ge-int(index, len) {
        this.list.reverse(acc)
      } else {
        let ch = _get-rune(t, index);
        if pred(ch) {
          let char-len = this.rune.size(ch);
          self(add-int(index, char-len), Cons(ch, acc))
        } else {
          this.list.reverse(acc)
        }
      }
    };
  pin cs = f(0, Nil);
  pack(cs)
}

inline take-while-end(t: string, !pred: (rune) -> bool) -> string {
  let len on t = string-byte-length(t);
  let f =
    define self(t: string, index: int) -> string {
      if lt-int(index, 0) {
        t
      } else {
        let rune-size on t = _get-rune-size-end(t, index);
        let rune-head-index = sub-int(index, sub-int(rune-size, 1));
        let ch on t = _get-rune(t, rune-head-index);
        if pred(ch) {
          self(t, sub-int(index, rune-size))
        } else {
          _drop(t, add-int(index, 1))
        }
      }
    };
  f(t, sub-int(len, 1))
}

inline take-while-end-N(t: &string, !pred: (rune) -> bool) -> string {
  let len = string-byte-length(t);
  let f =
    define self(t: &string, index: int) -> string {
      if lt-int(index, 0) {
        *t
      } else {
        let rune-size = _get-rune-size-end(t, index);
        let rune-head-index = sub-int(index, sub-int(rune-size, 1));
        let ch = _get-rune(t, rune-head-index);
        if pred(ch) {
          self(t, sub-int(index, rune-size))
        } else {
          _drop-N(t, add-int(index, 1))
        }
      }
    };
  f(t, sub-int(len, 1))
}

inline drop-while(t: string, !pred: (rune) -> bool) -> string {
  let f =
    define self(t: string) -> string {
      let b on t = this.string.is-empty(t);
      if b {
        empty()
      } else {
        let ch on t = _get-rune(t, 0);
        let cond = pred(ch);
        if cond {
          self(drop(t, 1))
        } else {
          t
        }
      }
    };
  f(t)
}

inline drop-while-N(t: &string, !pred: (rune) -> bool) -> string {
  let len = string-byte-length(t);
  let f =
    define self(index: int) -> string {
      if ge-int(index, len) {
        empty()
      } else {
        let ch = _get-rune(t, index);
        if pred(ch) {
          let char-len = this.rune.size(ch);
          self(add-int(index, char-len))
        } else {
          _drop-N(t, index)
        }
      }
    };
  f(0)
}

inline drop-while-end(t: string, !pred: (rune) -> bool) -> string {
  let len on t = string-byte-length(t);
  let f =
    define self(t: string, index: int) -> string {
      if lt-int(index, 0) {
        empty()
      } else {
        let rune-size on t = _get-rune-size-end(t, index);
        let rune-head-index = sub-int(index, sub-int(rune-size, 1));
        let ch on t = _get-rune(t, rune-head-index);
        if pred(ch) {
          self(t, sub-int(index, rune-size))
        } else {
          _take(t, add-int(index, 1))
        }
      }
    };
  f(t, sub-int(len, 1))
}

inline drop-while-end-N(t: &string, !pred: (rune) -> bool) -> string {
  let len = string-byte-length(t);
  let f =
    define self(t: &string, index: int) -> string {
      if lt-int(index, 0) {
        empty()
      } else {
        let rune-size = _get-rune-size-end(t, index);
        let rune-head-index = sub-int(index, sub-int(rune-size, 1));
        let ch = _get-rune(t, rune-head-index);
        if pred(ch) {
          self(t, sub-int(index, rune-size))
        } else {
          _take-N(t, add-int(index, 1))
        }
      }
    };
  f(t, sub-int(len, 1))
}

define replicate(t: &string, n: int) -> string {
  if le-int(n, 0) {
    empty()
  } else {
    let base-len = string-byte-length(t);
    let len = mul-int(n, base-len);
    let u = this.word.size;
    let u2 = mul-int(u, 2);
    let new-string = malloc(C-Size(add-int(len, u2)));
    store-int(0, new-string);
    store-int(len, shift(new-string, u));
    let content-ptr = shift(new-string, u2);
    let loop =
      define self(count: int, t: &string) -> unit {
        if ge-int(count, n) {
          Unit
        } else {
          let current-content-ptr = shift(content-ptr, mul-int(count, base-len));
          let x-ptr = _get-content-pointer(t);
          _copy-binary(x-ptr, current-content-ptr, base-len);
          self(add-int(count, 1), t)
        }
      };
    loop(0, t);
    magic cast(pointer, string, new-string)
  }
}

inline fold<a>(acc: a, t: &string, !f: (a, rune) -> a) -> a {
  let len = string-byte-length(t);
  let f =
    define self(index: int, acc: a) -> a {
      if ge-int(index, len) {
        acc
      } else {
        let ch = _get-rune(t, index);
        let char-len = this.rune.size(ch);
        self(add-int(index, char-len), f(acc, ch))
      }
    };
  f(0, acc)
}

inline all(t: &string, !pred: (rune) -> bool) -> bool {
  let len = string-byte-length(t);
  let f =
    define self(index: int) -> bool {
      if ge-int(index, len) {
        True
      } else {
        let ch = _get-rune(t, index);
        let cond = pred(ch);
        if cond {
          let char-len = this.rune.size(ch);
          self(add-int(index, char-len))
        } else {
          False
        }
      }
    };
  f(0)
}

inline any(t: &string, !pred: (rune) -> bool) -> bool {
  let len = string-byte-length(t);
  let f =
    define self(index: int) -> bool {
      if ge-int(index, len) {
        False
      } else {
        let ch = _get-rune(t, index);
        let cond = pred(ch);
        if cond {
          True
        } else {
          let char-len = this.rune.size(ch);
          self(add-int(index, char-len))
        }
      }
    };
  f(0)
}

define find(t: &string, !pred: (rune) -> bool) ->> ?int {
  let len = string-byte-length(t);
  let f =
    define self(byte-index: int, index: int) ->> ?int {
      if ge-int(byte-index, len) {
        none
      } else {
        let ch = _get-rune(t, byte-index);
        if pred(ch) {
          Right(index)
        } else {
          let char-len = this.rune.size(ch);
          self(add-int(byte-index, char-len), add-int(index, 1))
        }
      }
    };
  f(0, 0)
}

define find-end(t: &string, !pred: (rune) -> bool) ->> ?int {
  let len = string-byte-length(t);
  let f =
    define self(t: &string, byte-index: int, index: int) ->> ?int {
      if lt-int(byte-index, 0) {
        none
      } else {
        let rune-size = _get-rune-size-end(t, byte-index);
        let rune-head-byte-index = sub-int(byte-index, sub-int(rune-size, 1));
        let ch = _get-rune(t, rune-head-byte-index);
        if pred(ch) {
          Right(index)
        } else {
          self(t, sub-int(byte-index, rune-size), add-int(index, 1))
        }
      }
    };
  f(t, sub-int(len, 1), 0)
}

define strip-prefix(prefix: &string, haystack: string) -> string {
  let prefix = magic cast(&string, &binary, prefix);
  let haystack = magic cast(string, binary, haystack);
  _String(this.binary.strip-prefix(prefix, haystack))
}

define strip-suffix(suffix: &string, haystack: string) -> string {
  let suffix = magic cast(&string, &binary, suffix);
  let haystack = magic cast(string, binary, haystack);
  _String(this.binary.strip-suffix(suffix, haystack))
}
