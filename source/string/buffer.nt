import {
  this.binary.buffer,
  this.buffer {buffer, flush, make-buffer},
  this.either {Right},
  this.file.descriptor {stdout},
  this.rune.buffer {write-rune},
  this.string {string, to-binary},
  this.system {system},
  this.unit {Unit, unit},
}

define write(b: &buffer, content: &string) ->> system(unit) {
  this.binary.buffer.write-binary(b, to-binary(content))
}

define write-line(b: &buffer, content: &string) ->> system(unit) {
  try _ = write(b, content);
  write-rune(b, `\n`)
}

define zen() -> unit {
  let !k = make-buffer(stdout, 4096);
  pin k = k;
  let _: system(unit) = {
    try _ = write-line(k, "hello!");
    try _ = write-line(k, "hello!");
    try _ = flush(k);
    Right(Unit)
  };
  Unit
}
