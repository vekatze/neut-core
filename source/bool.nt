data bool {
| False
| True
}

inline-meta and(b1: 'bool, b2: 'bool) -> 'bool {
  quote {
    let b1 = unquote {b1};
    if b1 {
      unquote {b2}
    } else {
      False
    }
  }
}

inline-meta or(b1: 'bool, b2: 'bool) -> 'bool {
  quote {
    let b1 = unquote {b1};
    if b1 {
      True
    } else {
      unquote {b2}
    }
  }
}

inline not(b: bool) -> bool {
  if b {
    False
  } else {
    True
  }
}

rule-left any {
  inline-meta leaf(_: int) -> 'bool {
    quote {False}
  },
  inline-meta node-left(acc: 'bool, b: 'bool) -> 'bool {
    or(acc, b)
  },
  inline-meta root<a>(x: 'a) -> 'a {
    x
  },
}

rule-left all {
  inline-meta leaf(_: int) -> 'bool {
    quote {True}
  },
  inline-meta node-left(acc: 'bool, b: 'bool) -> 'bool {
    and(acc, b)
  },
  inline-meta root<a>(x: 'a) -> 'a {
    x
  },
}
