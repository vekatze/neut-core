import {
  this.box,
  this.show {Show, show},
  this.string {join, string},
  this.string.show {escape},
}

define show-rune(ch: rune) -> string {
  let base = this.string.singleton(ch);
  let result on base = join(escape(base));
  let _ = base;
  result
}

constant as-show: show(rune) {
  Show{
    render := {
      (ch) => {
        show-rune(*ch)
      }
    },
  }
}
