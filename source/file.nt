import {
  this.bool,
  this.either {Right},
  this.external,
  this.file.descriptor {descriptor},
  this.file.flag {flag},
  this.file.mode {mode},
  this.list {list},
  this.string {_get-content-pointer, string},
  this.system {report-system-error, system},
  this.unit {Unit, unit},
}

define open(path: &string, xs: list(flag), ms: list(mode)) ->> system(descriptor) {
  pin path = this.string.append(path, "\0");
  let actual-path-string = _get-content-pointer(path);
  let fd =
    this.external.open(
      actual-path-string,
      this.file.flag.interpret(xs),
      this.file.mode.interpret(ms),
    );
  if lt-int32(magic cast(descriptor, int32, fd), 0) {
    report-system-error()
  } else {
    Right(fd)
  }
}

define close(f: descriptor) ->> system(unit) {
  let result = this.external.close(f);
  if eq-int(result, 0) {
    Right(Unit)
  } else {
    report-system-error()
  }
}
