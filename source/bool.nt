data bool {
| False
| True
}

inline and(b1: bool, b2: bool) -> bool {
  if b1 {
    if b2 {
      True
    } else {
      False
    }
  } else {
    False
  }
}

inline or(b1: bool, b2: bool) -> bool {
  if b1 {
    True
  } else {
    if b2 {
      True
    } else {
      False
    }
  }
}

inline not(b: bool) -> bool {
  if b {
    False
  } else {
    True
  }
}

rule-left any {
  inline-meta leaf(_: int) -> 'bool {
    quote {False}
  },
  inline-meta node-left(acc: 'bool, b: 'bool) -> 'bool {
    quote {or(unquote {acc}, unquote {b})}
  },
  inline-meta root<a>(x: 'a) -> 'a {
    x
  },
}

rule-left all {
  inline-meta leaf(_: int) -> 'bool {
    quote {True}
  },
  inline-meta node-left(acc: 'bool, b: 'bool) -> 'bool {
    quote {and(unquote {acc}, unquote {b})}
  },
  inline-meta root<a>(x: 'a) -> 'a {
    x
  },
}
