import {
  this.bool {False, True, bool},
  this.eq {Eq, eq},
  this.vector {length, vector},
  this.vector.unsafe {access-unchecked},
}

inline as-eq<a>(class: eq(a)) -> eq(vector(a)) {
  let Eq{equal := !equal} = class;
  Eq{
    equal := {
      (xs, ys) => {
        let len1 = length(xs);
        let len2 = length(ys);
        if ne-int(len1, len2) {
          False
        } else {
          let f =
            define loop(i: int) -> bool {
              if ge-int(i, len1) {
                True
              } else {
                let x = access-unchecked(xs, i);
                let y = access-unchecked(ys, i);
                if equal(x, y) {
                  loop(add-int(i, 1))
                } else {
                  False
                }
              }
            };
          f(0)
        }
      }
    },
  }
}
