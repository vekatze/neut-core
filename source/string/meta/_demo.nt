import {
  this.binary,
  this.bool {False},
  this.bool.meta {or},
  this.debug.meta {assert},
  this.either {Left, Right},
  this.int.io {print-int-line},
  this.list {Cons, Nil},
  this.pair {Pair},
  this.string,
  this.string.meta,
  this.unit {Unit, unit},
}

define-meta _assert-basic() -> 'unit {
  quote {
    unquote {assert("string.meta: is-empty\n", this.string.meta.is-empty(""))};
    unquote {assert("string.meta: eq-string\n", this.string.meta.eq-string("abc", "abc"))};
    unquote {assert("string.meta: ne-string\n", this.string.meta.ne-string("abc", "abd"))};
    unquote {assert("string.meta: singleton\n", this.string.meta.eq-string(this.string.meta.singleton(`x`), "x"))};
    unquote {assert("string.meta: append\n", this.string.meta.eq-string(this.string.meta.append("ab", "cd"), "abcd"))};
    Unit
  }
}

define-meta _assert-substrings() -> 'unit {
  let s = "abcdef";
  let Pair(prefix, suffix) = this.string.meta.split-at(s, 2);
  quote {
    unquote {assert("string.meta: length\n", eq-int(this.string.meta.length(s), 6))};
    unquote {assert("string.meta: take\n", this.string.meta.eq-string(this.string.meta.take(s, 3), "abc"))};
    unquote {assert("string.meta: drop\n", this.string.meta.eq-string(this.string.meta.drop(s, 3), "def"))};
    unquote {assert("string.meta: slice\n", this.string.meta.eq-string(this.string.meta.slice(s, 2, 3), "cde"))};
    unquote {assert("string.meta: split-at prefix\n", this.string.meta.eq-string(prefix, "ab"))};
    unquote {assert("string.meta: split-at suffix\n", this.string.meta.eq-string(suffix, "cdef"))};
    unquote {assert("string.meta: take-end\n", this.string.meta.eq-string(this.string.meta.take-end(s, 2), "ef"))};
    unquote {assert("string.meta: drop-end\n", this.string.meta.eq-string(this.string.meta.drop-end(s, 2), "abcd"))};
    Unit
  }
}

define-meta _assert-search() -> 'unit {
  let s = "abcŃüédef";
  quote {
    unquote {assert("string.meta: eq-prefix\n", this.string.meta.eq-prefix(s, "abc"))};
    unquote {assert("string.meta: eq-suffix\n", this.string.meta.eq-suffix(s, "def"))};
    unquote {assert("string.meta: eq-infix\n", this.string.meta.eq-infix(s, "cŃüéd"))};
    unquote {assert("string.meta: find-string\n", this.string.meta.find-string(s, "Ńüéd"))};
    unquote {assert("string.meta: ne-string shorter\n", this.string.meta.ne-string(s, "abc"))};
    Unit
  }
}

define-meta _assert-fold-and-predicates() -> 'unit {
  let s = "aaabc";
  let is-a =
    (r) => {
      eq-rune(r, `a`)
    };
  let is-ascii-prefix =
    (r) => {
      or(eq-rune(r, `a`), or(eq-rune(r, `b`), eq-rune(r, `c`)))
    };
  let count =
    this.string.meta.fold(0, s, (acc, _) => {
      add-int(acc, 1)
    });
  let found =
    this.string.meta.find(s, (r) => {
      eq-rune(r, `b`)
    });
  match found {
  | Right(index) =>
    quote {
      unquote {assert("string.meta: fold\n", eq-int(count, 5))};
      unquote {assert("string.meta: drop-while\n", this.string.meta.eq-string(this.string.meta.drop-while(s, is-a), "bc"))};
      unquote {assert("string.meta: all\n", this.string.meta.all(s, is-ascii-prefix))};
      unquote {
        assert("string.meta: any\n", this.string.meta.any(s, (r) => {
          eq-rune(r, `b`)
        }))
      };
      unquote {assert("string.meta: find\n", eq-int(index, 3))};
      Unit
    }
  | Left(_) =>
    assert("string.meta: find\n", False)
  }
}

define-meta _assert-list-combinators() -> 'unit {
  let !xs = Cons("ab", Cons("cd", Cons("ef", Nil)));
  let joined = this.string.meta.concat(xs);
  let separated = this.string.meta.intercalate(xs, "-");
  quote {
    unquote {assert("string.meta: concat\n", this.string.meta.eq-string(joined, "abcdef"))};
    unquote {assert("string.meta: intercalate\n", this.string.meta.eq-string(separated, "ab-cd-ef"))};
    Unit
  }
}

define-meta _assert-strip() -> 'unit {
  quote {
    unquote {assert("string.meta: strip-prefix hit\n", this.string.meta.eq-string(this.string.meta.strip-prefix("abc", "abcdef"), "def"))};
    unquote {assert("string.meta: strip-prefix miss\n", this.string.meta.eq-string(this.string.meta.strip-prefix("xxx", "abcdef"), "abcdef"))};
    unquote {assert("string.meta: strip-suffix hit\n", this.string.meta.eq-string(this.string.meta.strip-suffix("def", "abcdef"), "abc"))};
    unquote {assert("string.meta: strip-suffix miss\n", this.string.meta.eq-string(this.string.meta.strip-suffix("xxx", "abcdef"), "abcdef"))};
    Unit
  }
}

define zen() -> unit {
  _assert-basic::();
  _assert-substrings::();
  _assert-search::();
  _assert-fold-and-predicates::();
  _assert-list-combinators::();
  _assert-strip::();
  print-int-line(1);
  Unit
}
