import {
  this.binary,
  this.bool {False, True, bool},
  this.either {Left, Right},
  this.list {Cons, Nil, list},
  this.pair {Pair, pair},
  this.string,
  this.unit {Unit},
}

inline-meta singleton(r: rune) -> text {
  magic text-cons(r, "")
}

inline-meta is-empty(t: text) -> bool {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    True
  | Right(_) =>
    False
  }
}

inline-meta append(t1: text, t2: text) -> text {
  let tmp = magic text-uncons(t1);
  match tmp {
  | Left(_) =>
    t2
  | Right(Pair(r, rest)) =>
    magic text-cons(r, append(rest, t2))
  }
}

inline-meta eq-text(t1: text, t2: text) -> bool {
  let tmp1 = magic text-uncons(t1);
  let tmp2 = magic text-uncons(t2);
  match tmp1, tmp2 {
  | Left(_), Left(_) =>
    True
  | Right(Pair(r1, rest1)), Right(Pair(r2, rest2)) =>
    if eq-rune(r1, r2) {
      eq-text(rest1, rest2)
    } else {
      False
    }
  | _, _ =>
    False
  }
}

inline-meta ne-text(t1: text, t2: text) -> bool {
  if eq-text(t1, t2) {
    False
  } else {
    True
  }
}

inline-meta length(t: text) -> int {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    0
  | Right(Pair(_, rest)) =>
    add-int(1, length(rest))
  }
}

inline-meta take(t: text, count: int) -> text {
  if le-int(count, 0) {
    ""
  } else {
    let tmp = magic text-uncons(t);
    match tmp {
    | Left(_) =>
      ""
    | Right(Pair(r, rest)) =>
      magic text-cons(r, take(rest, sub-int(count, 1)))
    }
  }
}

inline-meta drop(t: text, count: int) -> text {
  if le-int(count, 0) {
    t
  } else {
    let tmp = magic text-uncons(t);
    match tmp {
    | Left(_) =>
      t
    | Right(Pair(_, rest)) =>
      drop(rest, sub-int(count, 1))
    }
  }
}

inline-meta slice(t: text, start: int, count: int) -> text {
  take(drop(t, start), count)
}

inline-meta split-at(t: text, count: int) -> pair(text, text) {
  Pair(take(t, count), drop(t, count))
}

inline-meta take-end(t: text, count: int) -> text {
  let len = length(t);
  if ge-int(count, len) {
    t
  } else {
    drop(t, sub-int(len, count))
  }
}

inline-meta drop-end(t: text, count: int) -> text {
  let len = length(t);
  if ge-int(count, len) {
    ""
  } else {
    take(t, sub-int(len, count))
  }
}

inline-meta eq-prefix(t: text, prefix: text) -> bool {
  let prefix-tmp = magic text-uncons(prefix);
  match prefix-tmp {
  | Left(_) =>
    True
  | Right(Pair(prefix-rune, prefix-rest)) =>
    let t-tmp = magic text-uncons(t);
    match t-tmp {
    | Right(Pair(t-rune, t-rest)) =>
      if eq-rune(t-rune, prefix-rune) {
        eq-prefix(t-rest, prefix-rest)
      } else {
        False
      }
    | Left(_) =>
      False
    }
  }
}

inline-meta eq-suffix(t: text, suffix: text) -> bool {
  let t-len = length(t);
  let suffix-len = length(suffix);
  if lt-int(t-len, suffix-len) {
    False
  } else {
    eq-text(drop(t, sub-int(t-len, suffix-len)), suffix)
  }
}

inline-meta find-text(haystack: text, needle: text) -> bool {
  if eq-prefix(haystack, needle) {
    True
  } else {
    let tmp = magic text-uncons(haystack);
    match tmp {
    | Left(_) =>
      False
    | Right(Pair(_, rest)) =>
      find-text(rest, needle)
    }
  }
}

inline-meta eq-infix(t: text, piece: text) -> bool {
  find-text(t, piece)
}

inline-meta _take-while-count(t: text, !pred: (rune) -> bool) -> int {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    0
  | Right(Pair(r, rest)) =>
    if pred(r) {
      add-int(1, _take-while-count(rest, pred))
    } else {
      0
    }
  }
}

inline-meta drop-while(t: text, !pred: (rune) -> bool) -> text {
  drop(t, _take-while-count(t, pred))
}

inline-meta strip-prefix(prefix: text, haystack: text) -> text {
  if eq-prefix(haystack, prefix) {
    drop(haystack, length(prefix))
  } else {
    haystack
  }
}

inline-meta strip-suffix(suffix: text, haystack: text) -> text {
  if eq-suffix(haystack, suffix) {
    drop-end(haystack, length(suffix))
  } else {
    haystack
  }
}

inline-meta fold<a>(acc: a, t: text, !f: (a, rune) -> a) -> a {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    acc
  | Right(Pair(r, rest)) =>
    fold(f(acc, r), rest, f)
  }
}

inline-meta all(t: text, !pred: (rune) -> bool) -> bool {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    True
  | Right(Pair(r, rest)) =>
    if pred(r) {
      all(rest, pred)
    } else {
      False
    }
  }
}

inline-meta any(t: text, !pred: (rune) -> bool) -> bool {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    False
  | Right(Pair(r, rest)) =>
    if pred(r) {
      True
    } else {
      any(rest, pred)
    }
  }
}

inline-meta find(t: text, !pred: (rune) -> bool) -> ?int {
  let tmp = magic text-uncons(t);
  match tmp {
  | Left(_) =>
    Left(Unit)
  | Right(Pair(r, rest)) =>
    if pred(r) {
      Right(0)
    } else {
      match find(rest, pred) {
      | Left(_) =>
        Left(Unit)
      | Right(index) =>
        Right(add-int(index, 1))
      }
    }
  }
}

inline-meta concat(xs: list(text)) -> text {
  match xs {
  | Nil =>
    ""
  | Cons(y, ys) =>
    append(y, concat(ys))
  }
}

inline-meta intercalate(xs: list(text), sep: text) -> text {
  match xs {
  | Nil =>
    ""
  | Cons(y, Nil) =>
    y
  | Cons(y, Cons(z, ys)) =>
    append(y, append(sep, intercalate(Cons(z, ys), sep)))
  }
}
