data color-intensity {
| Dull
| Vivid
}

data color-layer {
| Foreground
| Background
}

data color-ansi {
| Black
| Red
| Green
| Yellow
| Blue
| Magenta
| Cyan
| White
}

data color {
| Color-16(color-intensity, color-ansi)
| Color-256(int8)
| Color-RGB(int8, int8, int8)
}

data span {
| From-Cursor
| To-Cursor
| Whole
}

data style {
| Normal
| Bold
| Faint
| Italic
| Underline
| Color(color-layer, color)
}

data cursor-movement {
| Up(int)
| Down(int)
| Forward(int)
| Backward(int)
| Up-Start(int)
| Down-Start(int)
| To-Column(int)
| To(int, int)
}

data space {
| Line
| Screen
}

data command {
| Set-Style(style)
| Move-Cursor(cursor-movement)
| Erase(space, span)
}
