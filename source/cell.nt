import {
  this.box {axiom-T},
  this.c-size {C-Size},
  this.memory {malloc},
  this.memory.unsafe {free, load-int, store-int},
  this.pair {Pair, pair},
  this.pointer {shift},
  this.unit {Unit, unit},
  this.unsafe {cast-inline},
  this.word,
}

inline _get-clone<a>(x: &a) -> a {
  *x
}

nominal {
  resource _cell,
}

data cell(_: type) {
| _Cell(_cell)
}

inline _make<a>(val: a) -> cell(a) {
  let u = this.word.size;
  let ptr = malloc(C-Size(mul-int(this.word.size, 2)));
  store-int(cast-inline<a, int>(val), ptr);
  store-int(cast-inline<type, int>(pack-type {a}), shift(ptr, u));
  _Cell(cast-inline<pointer, _cell>(ptr))
}

// (content, type)
resource _cell {
  (r: pointer) => {
    let u = this.word.size;
    unpack-type a = cast-inline<int, type>(load-int(shift(r, u)));
    let _: a = cast-inline<int, a>(load-int(r));
    free(r)
  },
  (r: pointer) => {
    let u = this.word.size;
    unpack-type a = cast-inline<int, type>(load-int(shift(r, u)));
    let val: &a = cast-inline<int, &a>(load-int(r));
    let val-clone: a = _get-clone<a>(val);
    cast-inline<cell(a), pointer>(_make<a>(val-clone))
  },
  -1,
}

inline make-cell<a>(initial-value: +a) -> cell(a) {
  _make<a>(axiom-T(initial-value))
}

inline modify<a, b>(r: &cell(a), f: (+a) -> pair(+a, b)) -> b {
  let r = cast-inline<&cell(a), pointer>(r);
  let orig-val = cast-inline<int, +a>(load-int(r));
  let Pair(new-val, result) = f(orig-val);
  store-int(cast-inline<+a, int>(new-val), r);
  result
}

inline mutate<a>(r: &cell(a), f: (+a) -> +a) -> unit {
  modify(r, (x) => {
    Pair(f(x), Unit)
  })
}

inline borrow<a, b>(r: &cell(a), f: (&a) -> +b) -> b {
  let r = cast-inline<&cell(a), pointer>(r);
  let orig-val = cast-inline<int, &a>(load-int(r));
  letbox-T result = f(orig-val);
  result
}

inline clone<a>(r: &cell(a)) -> a {
  modify(r, (!val: +a) => {
    Pair(val, axiom-T(val))
  })
}

inline extract<a>(c: cell(a)) -> +a {
  letbox-T result on c = {
    let r = cast-inline<&cell(a), pointer>(c);
    cast-inline<int, ++a>(load-int(r))
  };
  free(cast-inline<cell(a), pointer>(c));
  result
}
