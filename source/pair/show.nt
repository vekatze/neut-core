import {
  this.box,
  this.list {List},
  this.pair {Pair, pair},
  this.show {Show, show},
  this.string {intercalate, join},
}

inline as-show<a, b>(s1: show(a), s2: show(b)) -> show(pair(a, b)) {
  Show{
    render := {
      (p: &pair(a, b)) => {
        tie Pair(x, y) = p;
        let Show{render := render1} = s1;
        let Show{render := render2} = s2;
        join(List[
          *"(",
          intercalate(List[render1(x), render2(y)], *", "),
          *")",
        ])
      }
    },
  }
}
