import {
  this.box,
  this.list {List, for-each-N, list},
  this.show {Show, show},
  this.string {intercalate, join},
}

inline as-show<a>(s: show(a)) -> show(list(a)) {
  Show((xs) => {
    let Show{render} = s;
    let ys = for-each-N(xs, render);
    join(List[*"[", intercalate(ys, *", "), *"]"])
  })
}
