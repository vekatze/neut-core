import {
  this.bool,
  this.c-string {c-string, to-string},
  this.either {Right, none},
  this.pointer {is-null-pointer},
  this.string {string},
  this.string.pointer {get-content-pointer},
  this.unit,
  this.unsafe {cast},
}

foreign {
  getenv(pointer) -> pointer,
}

define get-env(name: &string) ->> ?string {
  let c-str = get-content-pointer(name);
  let tmp = magic external getenv(c-str);
  if is-null-pointer(tmp) {
    none
  } else {
    Right(to-string(cast<pointer, &c-string>(tmp)))
  }
}
