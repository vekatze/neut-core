import {
  this.c-size {C-Size},
  this.memory {malloc},
  this.memory.unsafe {free, memcpy, store-int, store-int8},
  this.pointer {shift},
  this.string {byte-length, string},
  this.string.pointer,
  this.unit,
  this.unsafe {cast},
  this.word,
}

foreign {
  strlen(pointer) -> int,
}

nominal {
  resource c-string,
}

define _length-c-string(s: pointer) -> int {
  magic external strlen(s)
}

// null-terminated string
resource c-string {
  (ptr: pointer) => {
    free(ptr)
  },
  (ptr: pointer) => {
    let total = add-int(_length-c-string(ptr), 1);
    let new-ptr = malloc(C-Size(total));
    memcpy(new-ptr, ptr, total);
    new-ptr
  },
  -1,
}

define length(s: &c-string) -> int {
  _length-c-string(magic cast(&c-string, pointer, s))
}

define from-string(t: &string) -> c-string {
  let len = byte-length(t);
  let new-ptr = malloc(C-Size(add-int(len, 1)));
  let src-ptr = this.string.pointer.get-content-pointer(t);
  memcpy(new-ptr, src-ptr, len);
  store-int8(0, shift(new-ptr, len));
  cast<pointer, c-string>(new-ptr)
}

define to-string(s: &c-string) -> string {
  let u = this.word.size;
  let u2 = mul-int(u, 2);
  let len = length(s);
  let new-ptr = malloc(C-Size(add-int(len, u2)));
  store-int(0, new-ptr);
  store-int(len, shift(new-ptr, u));
  memcpy(shift(new-ptr, u2), magic cast(&c-string, pointer, s), len);
  cast<pointer, string>(new-ptr)
}
