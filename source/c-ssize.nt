import {
  this.bool {bool},
}

alias _c-ssize {
  int64
}

data c-ssize {
| C-SSize(_c-ssize)
}

inline from-c-ssize(x: c-ssize) -> int {
  let C-SSize(x) = x;
  x
}

inline add-c-ssize(x: c-ssize, y: c-ssize) -> c-ssize {
  let C-SSize(x) = x;
  let C-SSize(y) = y;
  C-SSize(add-int(x, y))
}

inline mul-c-ssize(x: c-ssize, y: c-ssize) -> c-ssize {
  let C-SSize(x) = x;
  let C-SSize(y) = y;
  C-SSize(mul-int(x, y))
}

inline lt-c-ssize(x: c-ssize, y: c-ssize) -> bool {
  let C-SSize(x) = x;
  let C-SSize(y) = y;
  lt-int(x, y)
}

inline eq-c-ssize(x: c-ssize, y: c-ssize) -> bool {
  let C-SSize(x) = x;
  let C-SSize(y) = y;
  eq-int(x, y)
}
