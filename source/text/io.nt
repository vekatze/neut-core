import {
  this.binary {binary},
  this.binary.io,
  this.bool,
  this.either {Left, Right},
  this.file.descriptor {descriptor, stdin, stdout},
  this.magic,
  this.system {get-error-message, report-system-error, system},
  this.text {_get-content-pointer, text, text-byte-length, to-binary},
  this.unit {Unit, unit},
}

foreign {
  neut_core_v0_52_write_line(int32, int, pointer): int,
}

define write(f: descriptor, t: &text) ->> system(unit) {
  this.binary.io.write(f, to-binary(t))
}

define write-line(d: descriptor, t: &text) ->> system(unit) {
  let d = magic cast(descriptor, int32, d);
  let len = text-byte-length(t);
  let ptr = _get-content-pointer(t);
  let result = magic external neut_core_v0_52_write_line(d, len, ptr);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define print(t: &text) -> unit {
  match write(stdout, t) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define print-line(t: &text) -> unit {
  match write-line(stdout, t) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define read(from: descriptor, initial-buffer-size: int) ->> system(text) {
  try bin = this.binary.io.read(from, initial-buffer-size);
  Right(this.magic.cast<binary, text>(bin))
}

define read-stdin(initial-buffer-size: int) ->> system(text) {
  read(stdin, initial-buffer-size)
}

define zen() -> unit {
  // print("hey\n");
  // Unit
  let _ = write(stdout, "hello.\n");
  let value = read(stdin, 10);
  match value {
  | Right(_) =>
    // pin txt = _Text(value);
    print// print(txt)
    ("success\n")
  | Left(e) =>
    pin text = get-error-message(e);
    print(text);
    print("\n")
  }
}
