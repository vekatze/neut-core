import {
  this.bool,
  this.box,
  this.c-int {eq-c-int},
  this.c-size {C-Size, add-c-size, c-size, from-c-size, mul-c-size},
  this.memory {malloc},
  this.memory.unsafe {free, load-int, load-int8, load-pointer, store-int, store-int8},
  this.pointer {return-or-store-pointer, shift},
  this.sync._posix {
    THREAD_MUTEX_SIZE,
    THREAD_SIZE,
    thread-create,
    thread-exit,
    thread-join,
    thread-mutex-destroy,
    thread-mutex-init,
    thread-mutex-lock,
    thread-mutex-unlock,
  },
  this.unit {Unit, unit},
  this.unsafe {cast},
  this.word,
}

inline _embody<a>(x: &a) -> a {
  *x
}

inline _thread-size() -> c-size {
  let u = this.word.size;
  add-c-size(add-c-size(mul-c-size(C-Size(u), C-Size(3)), THREAD_MUTEX_SIZE), C-Size(1))
}

inline _get-mutex-ptr(addr: pointer) -> pointer {
  let u = this.word.size;
  shift(addr, mul-int(u, 3))
}

inline _get-finished-flag-ptr(addr: pointer) -> pointer {
  let u = this.word.size;
  let mutex-size = from-c-size(THREAD_MUTEX_SIZE);
  shift(addr, add-int(mul-int(u, 3), mutex-size))
}

nominal {
  define _await-and-write-result(addr: pointer) -> unit,
  alias-opaque thread(_: type),
  define join<a>(e: thread(a)) -> a,
}

resource _thread-inner {
  (addr: pointer, _: int) => {
    let u = this.word.size;
    unpack-type elem-type = cast<int, type>(load-int(shift(addr, u)));
    let pr: thread(elem-type) = cast<pointer, thread(elem-type)>(addr);
    let _: elem-type = this.sync.thread.join<elem-type>(pr);
    Unit
  },
  (addr: pointer, dest: pointer) => {
    let u = this.word.size;
    let u2 = mul-int(u, 2);
    _await-and-write-result(addr);
    let thread-id = load-int(addr);
    unpack-type elem-type = cast<int, type>(load-int(shift(addr, u)));
    let elem-value: &elem-type = cast<int, &elem-type>(load-int(shift(addr, u2)));
    let new-addr = malloc(_thread-size());
    store-int(thread-id, new-addr);
    store-int(cast<type, int>(pack-type {elem-type}), shift(new-addr, u));
    let cloned-value: elem-type = _embody<elem-type>(elem-value);
    store-int(cast<elem-type, int>(cloned-value), shift(new-addr, u2));
    let _ = thread-mutex-init(_get-mutex-ptr(new-addr));
    store-int8(1, _get-finished-flag-ptr(new-addr));
    return-or-store-pointer(new-addr, dest)
  },
  -1,
}

// `thread` must be defined by `alias-opaque` (and not by `data`) so that
// `thread(a)` is considered to be possibly noetic
alias-opaque thread(_: type) {
  _thread-inner
}

define join<a>(e: thread(a)) -> a {
  let addr = cast<thread(a), pointer>(e);
  _await-and-write-result(addr);
  let u = this.word.size;
  let value-ptr = shift(addr, mul-int(u, 2));
  let value = load-int(value-ptr);
  thread-mutex-destroy(_get-mutex-ptr(addr));
  free(addr);
  cast<int, a>(value)
}

define _await-and-write-result(addr: pointer) -> unit {
  let u = this.word.size;
  let u2 = mul-int(u, 2);
  let mutex-ptr = _get-mutex-ptr(addr);
  let finished-flag-ptr = _get-finished-flag-ptr(addr);
  thread-mutex-lock(mutex-ptr);
  let finished-flag = load-int8(finished-flag-ptr);
  if eq-int8(finished-flag, 0) {
    let thread-id = load-pointer(addr);
    let value-ptr = shift(addr, u2);
    thread-join(thread-id, value-ptr);
    store-int8(1, finished-flag-ptr);
    thread-mutex-unlock(mutex-ptr)
  } else {
    thread-mutex-unlock(mutex-ptr)
  }
}

// (thread-id, result-type, result-value, mutex, finished-flag): thread(result-type)
define spawn<a>(f: () -> a) -> thread(a) {
  let thread-func =
    () => {
      thread-exit(cast<a, pointer>(f()))
    };
  let u = this.word.size;
  let u2 = mul-int(u, 2);
  let closure = cast<() -> unit, pointer>(thread-func);
  let closure-env = load-pointer(shift(closure, u));
  let closure-label = load-pointer(shift(closure, u2));
  free(closure);
  let thread-id-pointer = malloc(THREAD_SIZE);
  let thread-create =
    define naive-loop() -> unit {
      let result = thread-create(thread-id-pointer, closure-label, closure-env);
      if eq-c-int(result, 0) {
        Unit
      } else {
        naive-loop()
      }
    };
  let _ = thread-create();
  let thread-id = load-int(thread-id-pointer);
  free(thread-id-pointer);
  let ptr = malloc(_thread-size());
  store-int(thread-id, ptr);
  store-int(cast<type, int>(pack-type {a}), shift(ptr, u));
  store-int(0, shift(ptr, u2));
  let _ = thread-mutex-init(_get-mutex-ptr(ptr));
  store-int8(0, _get-finished-flag-ptr(ptr));
  cast<pointer, thread(a)>(ptr)
}
