import {
  this.binary,
  this.either,
  this.file.buffer {flush, make-buffer},
  this.file.descriptor {stdout},
  this.float.io.buffer {write-float, write-float-line},
  this.string,
  this.string.io.buffer {write},
  this.system {system},
  this.unit {Unit, unit},
}

define zen() -> unit {
  pin b = make-buffer(stdout, 10);
  let _: system(unit) = {
    try _ = write-float(b, 3.141592);
    try _ = write(b, "\n");
    try _ = write-float(b, 3.141592);
    try _ = write(b, "\n");
    try _ = write-float(b, 3333333333.141592);
    try _ = write(b, "\n");
    try _ = write-float(b, 0.0);
    try _ = write(b, "\n");
    try _ = write-float(b, 0.0);
    try _ = write(b, "\n");
    try _ = write-float(b, -0.0);
    try _ = write(b, "\n");
    try _ = write-float(b, -0.0);
    try _ = write(b, "\n");
    try _ = write-float(b, 1.0);
    try _ = write(b, "\n");
    try _ = write-float(b, -1.0);
    try _ = write(b, "\n");
    try _ = write-float(b, 3.141592653589793);
    try _ = write(b, "\n");
    try _ = write-float(b, 1.0e-40);
    try _ = write(b, "\n");
    try _ = write-float(b, 1.0e38);
    try _ = write(b, "\n");
    try _ = write-float(b, -1.0e38);
    try _ = write(b, "\n");
    try _ = write-float(b, 1.17549435e-38);
    try _ = write(b, "\n");
    try _ = write-float(b, 1.40129846e-45);
    try _ = write(b, "\n");
    try _ = write-float(b, -1.40129846e-45);
    try _ = write(b, "\n");
    try _ = write-float-line(b, -3.141592);
    try _ = write-float-line(b, 0.0);
    try _ = write-float-line(b, -0.0);
    try _ = write-float-line(b, 1.0);
    try _ = write-float-line(b, -1.0);
    try _ = write-float-line(b, 3.141592653589793);
    try _ = write-float-line(b, 1.0e-40);
    try _ = write-float-line(b, 1.0e38);
    try _ = write-float-line(b, -1.0e38);
    try _ = write-float-line(b, 1.17549435e-38);
    try _ = write-float-line(b, 1.40129846e-45);
    try _ = write-float-line(b, -1.40129846e-45);
    flush(b)
  };
  Unit
}
