import {
  this.bool {bool},
  this.external {exit},
  this.string {string},
  this.string.io {print},
  this.unit {Unit, unit},
}

define panic<a>(t: &string) -> a {
  print(t);
  exit(1)
}

inline _assert(message: &string, check: () -> bool) -> unit {
  introspect build-mode {
  | release =>
    let _ = check;
    let _ = message;
    Unit
  | default =>
    if check() {
      Unit
    } else {
      panic(message)
    }
  }
}
