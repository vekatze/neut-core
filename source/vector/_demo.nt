import {
  this.bool,
  this.box,
  this.debug {assert, panic},
  this.either {Left, Right},
  this.int.io {print-int-line},
  this.list {List},
  this.pair {Pair},
  this.string {replicate, string},
  this.string.io {print, print-line},
  this.unit {Unit, unit},
  this.vector {
    access,
    delete,
    drop,
    find,
    for,
    for-each-N,
    from-list,
    length,
    make,
    pop-back,
    push-back,
    push-front,
    reverse,
    take,
    to-list,
    vector,
    with-slice,
    zip-with-N,
  },
}

define _expect-access(label: &string, xs: &vector(int), index: int, expected: int) -> unit {
  match access(xs, index) {
  | Left(_) =>
    panic(label)
  | Right(actual) =>
    assert(label, eq-int(*actual, expected))
  }
}

define _expect-no-access(label: &string, xs: &vector(int), index: int) -> unit {
  match access(xs, index) {
  | Left(_) =>
    Unit
  | Right(_) =>
    panic(label)
  }
}

define _expect-slice-3(label: &string, source: &vector(int), start: int, size: int, x0: int, x1: int, x2: int) -> unit {
  with-slice(source, start, size, (slice) => {
    lift {
      assert(label, eq-int(length(slice), 3));
      _expect-access(label, slice, 0, x0);
      _expect-access(label, slice, 1, x1);
      _expect-access(label, slice, 2, x2)
    }
  })
}

define _expect-slice-2(label: &string, source: &vector(int), start: int, size: int, x0: int, x1: int) -> unit {
  with-slice(source, start, size, (slice) => {
    lift {
      assert(label, eq-int(length(slice), 2));
      _expect-access(label, slice, 0, x0);
      _expect-access(label, slice, 1, x1)
    }
  })
}

define _expect-empty-slice(label: &string, source: &vector(int), start: int, size: int) -> unit {
  with-slice(source, start, size, (slice) => {
    lift {
      assert(label, eq-int(length(slice), 0));
      _expect-no-access(label, slice, 0)
    }
  })
}

define _expect-materialized-copy(label: &string, source: &vector(int), start: int, size: int, x0: int, x1: int, x2: int) -> unit {
  with-slice(source, start, size, (slice) => {
    lift {
      pin copied =
        for-each-N(slice, (x, _) => {
          *x
        });
      assert(label, eq-int(length(copied), 3));
      _expect-access(label, copied, 0, x0);
      _expect-access(label, copied, 1, x1);
      _expect-access(label, copied, 2, x2)
    }
  })
}

define _assert-vector-layout() -> unit {
  let xs: vector(int) = make(0);
  let xs = push-back(xs, 20);
  let xs = push-back(xs, 30);
  let xs = push-back(xs, 40);
  let xs = push-front(xs, 10);
  let xs = push-back(xs, 50);
  pin xs = push-front(xs, 0);
  assert("vector inline buffer: length after growth\n", eq-int(length(xs), 6));
  _expect-access("vector inline buffer: front growth\n", xs, 0, 0);
  _expect-access("vector inline buffer: middle after growth\n", xs, 3, 30);
  _expect-access("vector inline buffer: back growth\n", xs, 5, 50);
  _expect-slice-3("vector.with-slice: middle\n", xs, 2, 3, 20, 30, 40);
  _expect-slice-2("vector.with-slice: negative start clamps to zero\n", xs, -10, 2, 0, 10);
  _expect-slice-3("vector.with-slice: oversized size clamps to end\n", xs, 3, 99, 30, 40, 50);
  _expect-empty-slice("vector.with-slice: oversized start clamps to end\n", xs, 99, 4);
  _expect-empty-slice("vector.with-slice: negative size clamps to zero\n", xs, 2, -5);
  _expect-materialized-copy("vector.with-slice: materialized copy\n", xs, 2, 3, 20, 30, 40);
  let shifted = drop(from-list(List[0, 1, 2, 3, 4, 5, 6]), 2);
  pin shifted = take(shifted, 4);
  _expect-slice-2("vector.with-slice: non-zero from\n", shifted, 1, 2, 3, 4)
}

define zen() -> unit {
  _assert-vector-layout();
  // find
  let xs = this.vector.make(5);
  let xs = push-back(xs, 1);
  let xs = push-back(xs, 2);
  let xs = push-back(xs, 3);
  let xs = push-back(xs, 4);
  pin xs = push-back(xs, 5);
  let item =
    find(xs, (x) => {
      eq-int(*x, -1)
    });
  match item {
  | Left(_) =>
    print-line("left")
  | Right(x) =>
    print-line("right");
    print-int-line(*x);
  };
  let xs: vector(string) = make(0);
  let xs = push-back(xs, *"b");
  let xs = push-front(xs, *"a");
  let xs = push-front(xs, *"c");
  let !xs = drop(xs, 2);
  let _ = xs;
  let _ = xs;
  let _ = xs;
  let xs = push-front(xs, *"d");
  let xs = push-back(xs, *"e");
  let xs = push-front(xs, *"f");
  let xs = push-back(xs, *"g");
  let xs = push-front(xs, *"h");
  let !xs = xs;
  // let !xs = drop(xs, 3);
  let _ = xs;
  // let xs = drop(xs, 3);
  let _ = xs;
  let _ = xs;
  let _ = push-front(xs, *"foo");
  let _ = xs;
  let _ = xs;
  let _ = xs;
  // let xs = push-back(xs, 7);
  // let xs = push-back(xs, 8);
  // let xs = push-back(xs, 9);
  // let xs = push-back(xs, 10);
  // let xs = take(xs, 5);
  // let !xs = delete(xs, 0);
  // let _ = !xs;
  // let _ = !xs;
  // let _ = !xs;
  // let _ = !xs;
  let xs-clone = xs;
  pin xs = xs;
  let ys: vector(int) = from-list(to-list(from-list(List[1, 2, 3, 4, 5])));
  pin ys = ys;
  let zs =
    zip-with-N(xs, ys, (x, y, _) => {
      replicate(x, *y)
    });
  let !zs = delete(reverse(zs), 100);
  let _ = zs;
  let _ = zs;
  match pop-back(zs) {
  | Left(_) =>
    print("left\n")
  | Right(Pair(!rest, z)) =>
    let _ = rest;
    let _ = rest;
    let len on rest = length(rest);
    let _ = rest;
    print("right. last-elem = ");
    let _ on z = print-line(z);
    let _ = z;
    print("len = ");
    print-int-line(len)
  };
  pin zs = zs;
  for(*zs, (x, _) => {
    pin x = x;
    print(x);
    print(", ")
  });
  print("\n----\n");
  for(xs-clone, (x, _) => {
    pin x = x;
    print(x);
    print(", ")
  });
  print("\n")
}
