import {
  this.binary,
  this.either {Left, Right, either},
  this.list {List},
  this.show {Show, show},
  this.string {format},
}

inline as-show<a, b>(s1: show(a), s2: show(b)) -> show(either(a, b)) {
  Show((val) => {
    case val {
    | Left(x) =>
      let Show{render} = s1;
      format("Left({})", List[render(x)])
    | Right(y) =>
      let Show{render} = s2;
      format("Right({})", List[render(y)])
    }
  })
}
