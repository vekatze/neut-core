import {
  this.c-int {add-c-int, c-int, from-c-int},
  this.c-size {C-Size},
  this.external {malloc},
  this.memory {store-int},
  this.pointer {null-pointer, shift},
  this.show {Show, show},
  this.string {_get-content-pointer, string},
  this.unit,
  this.word,
}

foreign {
  snprintf(pointer, c-int, pointer) -> c-int,
  sprintf(pointer, pointer) -> c-int,
}

define _show(c-fmt: &string, x: float) -> string {
  let fmt = _get-content-pointer(c-fmt);
  let size = magic external snprintf(null-pointer, 0, fmt)(x: float);
  let ptr = this.external.malloc(C-Size(add-int(from-c-int(add-c-int(size, 1)), mul-int(this.word.size, 2))));
  store-int(0, ptr);
  store-int(from-c-int(size), shift(ptr, this.word.size));
  let buffer = shift(ptr, mul-int(this.word.size, 2));
  let _ = magic external snprintf(buffer, add-c-int(size, 1), fmt)(x: float);
  magic cast(pointer, string, ptr)
}

foreign {
  neut_core_v0_54_build_fixed_buf(pointer, int, float, int, int) -> int,
}

define show-float(x: float, decimals: int) -> string {
  let size = 80;
  let add-newline = 0;
  let string-ptr = malloc(C-Size(size));
  let word-size = this.word.size;
  let buffer-ptr = shift(string-ptr, mul-int(word-size, 2));
  let len = magic external neut_core_v0_54_build_fixed_buf(buffer-ptr, size, x, decimals, add-newline);
  store-int(0, string-ptr);
  store-int(len, shift(string-ptr, word-size));
  magic cast(pointer, string, string-ptr)
}

constant as-show: show(float) {
  Show((x) => {
    show-float(x, 6)
  })
}
