import {
  this.bool {bool},
  this.process {exit},
  this.string {string},
  this.string.io {print},
  this.unit {Unit, unit},
}

define panic<a>(t: &string) -> a {
  print(t);
  exit(1)
}

define assert(message: &string, cond: bool) -> unit {
  if cond {
    Unit
  } else {
    panic(message)
  }
}
