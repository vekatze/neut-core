inline flip<a, b, c>(f: (a, b) -> c) -> (b, a) -> c {
  (y, x) => {
    f(x, y)
  }
}

inline compose<a, b, c>(g: (b) -> c, f: (a) -> b) -> (a) -> c {
  (x) => {
    g(f(x))
  }
}

inline curry<a, b, c>(f: (a, b) -> c) -> (a) -> (b) -> c {
  (x) => {
    (y) => {
      f(x, y)
    }
  }
}

inline uncurry<a, b, c>(f: (a) -> (b) -> c) -> (a, b) -> c {
  (x, y) => {
    f(x)(y)
  }
}

rule-left pipeline {
  inline leaf<a>(_: int) -> _ {
    (x: a) => {
      x
    }
  },
  inline node-left<a, b, c>(acc: (a) -> b, g: (b) -> c) -> (a) -> c {
    (x: a) => {
      g(acc(x))
    }
  },
  inline root<a>(x: a) -> a {
    x
  },
}
