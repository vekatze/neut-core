import {
  this.bool,
  this.either {Left, Right},
  this.memory.unsafe {load-int},
  this.string {string},
  this.string.pointer {get-content-pointer},
  this.unit {Unit},
}

foreign {
  neut_core_v0_55_parse_binary(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_binary_digits(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_octal(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_octal_digits(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_decimal(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_decimal_digits(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_hex(pointer, int, pointer) -> int,
  neut_core_v0_55_parse_hex_digits(pointer, int, pointer) -> int,
}

inline _parse_binary(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_binary(num-str-ptr, len, result-ptr)
}

inline _parse_binary_digits(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_binary_digits(num-str-ptr, len, result-ptr)
}

inline _parse_octal(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_octal(num-str-ptr, len, result-ptr)
}

inline _parse_octal_digits(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_octal_digits(num-str-ptr, len, result-ptr)
}

inline _parse_decimal(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_decimal(num-str-ptr, len, result-ptr)
}

inline _parse_decimal_digits(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_decimal_digits(num-str-ptr, len, result-ptr)
}

inline _parse_hex(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_hex(num-str-ptr, len, result-ptr)
}

inline _parse_hex_digits(num-str-ptr: pointer, len: int, result-ptr: pointer) -> int {
  magic external neut_core_v0_55_parse_hex_digits(num-str-ptr, len, result-ptr)
}

define parse-binary(t: &string) ->> ?int {
  let c-int-str = get-content-pointer(t);
  let len = this.string.byte-length(t);
  let result-ptr = magic alloca(int, 1);
  let result-status = _parse_binary(c-int-str, len, result-ptr);
  if lt-int(result-status, 0) {
    Left(Unit)
  } else {
    let result = load-int(result-ptr);
    Right(result)
  }
}

define parse-octal(t: &string) ->> ?int {
  let c-int-str = get-content-pointer(t);
  let len = this.string.byte-length(t);
  let result-ptr = magic alloca(int, 1);
  let result-status = _parse_octal(c-int-str, len, result-ptr);
  if lt-int(result-status, 0) {
    Left(Unit)
  } else {
    let result = load-int(result-ptr);
    Right(result)
  }
}

define parse-int(t: &string) ->> ?int {
  let c-int-str = get-content-pointer(t);
  let len = this.string.byte-length(t);
  let result-ptr = magic alloca(int, 1);
  let result-status = _parse_decimal(c-int-str, len, result-ptr);
  if lt-int(result-status, 0) {
    Left(Unit)
  } else {
    let result = load-int(result-ptr);
    Right(result)
  }
}

