import {
  this.either {Left, Right},
  this.file.buffer {flush, make-buffer},
  this.file.descriptor {stdout},
  this.rune.io.buffer {write-rune, write-rune-line},
  this.string,
  this.string.io {print-line},
  this.system {system},
  this.unit {Unit, unit},
}

define zen() -> unit {
  let !k = make-buffer(stdout, 4);
  pin k = k;
  let test: system(unit) = {
    try _ = write-rune(k, `a`);
    try _ = write-rune(k, `b`);
    try _ = write-rune(k, `あ`);
    try _ = write-rune-line(k, `α`);
    try _ = write-rune(k, `a`);
    try _ = write-rune(k, `b`);
    try _ = write-rune(k, `あ`);
    try _ = write-rune-line(k, `α`);
    try _ = flush(k);
    Right(Unit)
  };
  match test {
  | Left(_) =>
    print-line("left");
  | Right(_) =>
    print-line("right");
  }
}
