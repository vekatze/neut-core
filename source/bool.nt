data bool {
| False
| True
}

inline and(b1: bool, b2: bool) -> bool {
  if b1 {
    if b2 {
      True
    } else {
      False
    }
  } else {
    False
  }
}

inline or(b1: bool, b2: bool) -> bool {
  if b1 {
    True
  } else {
    if b2 {
      True
    } else {
      False
    }
  }
}

inline not(b: bool) -> bool {
  if b {
    False
  } else {
    True
  }
}

rule-left any {
  inline leaf(_: int) -> bool {
    False
  },
  inline node-left(acc: bool, b: bool) -> bool {
    or(acc, b)
  },
  inline root<a>(x: a) -> a {
    x
  },
}

rule-left all {
  inline foo(_: int) -> _ {
    True
  },
  inline node-left(acc: bool, b: bool) -> bool {
    and(acc, b)
  },
  inline root<a>(x: a) -> a {
    x
  },
}
