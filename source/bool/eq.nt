import {
  this.bool {False, True, bool},
  this.box,
  this.eq {Eq, eq},
}

define eq-bool(b1: bool, b2: bool) -> bool {
  match b1, b2 {
  | True, True =>
    True
  | False, False =>
    True
  | _, _ =>
    False
  }
}

constant as-eq: eq(bool) {
  Eq(
    (b1, b2) => {
      eq-bool(*b1, *b2)
    },
  )
}
