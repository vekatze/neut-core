import {
  this.bool {bool},
  this.list {list},
  this.string {string},
}

data field-layout {
| Direct
| Mixed(slot-count: int)
}

data field {
| Field(
    name: &string,
    field-type: type,
    layout: field-layout,
  )
}

data constructor {
| Constructor(&string, bool, list(field))
}

data type-value {
| Opaque
| Type
| Function
| Algebraic(data-name: &string, data-param-types: list(type), constructors: list(constructor))
| Noema(type)
| Enum(constructors: list(&string))
| Int1
| Int2
| Int4
| Int8
| Int16
| Int32
| Int64
| Float16
| Float32
| Float64
| Pointer
| Null
| Rune
| Binary
| Vector(type)
| Wrapper(type)
| Box-T(type)
}
