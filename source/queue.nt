import {
  this.bool {False, True, bool},
  this.either {Right, none},
  this.list {Cons, Nil, length, list, reverse},
  this.pair {Pair, pair},
  this.unit,
}

// naive queue
data queue(a: type) {
| _Queue(list(a), list(a))
}

constant empty<a>: queue(a) {
  _Queue(Nil, Nil)
}

define dequeue<a>(q: queue(a)) -> ?pair(a, queue(a)) {
  let _Queue(ls, rs) = q;
  match ls, rs {
  | Nil, Nil =>
    none
  | Cons(l, ls-rest), rs =>
    Right(Pair(l, _Queue(ls-rest, rs)))
  | Nil, rs =>
    dequeue(_Queue(reverse(rs), Nil))
  }
}

define enqueue<a>(q: queue(a), x: a) -> queue(a) {
  let _Queue(ls, rs) = q;
  _Queue(ls, Cons(x, rs))
}

define size<a>(q: &queue(a)) -> int {
  case q {
  | _Queue(ls, rs) =>
    let l1 = length(ls);
    let l2 = length(rs);
    add-int(l1, l2)
  }
}

define is-empty<a>(q: &queue(a)) -> bool {
  case q {
  | _Queue(Nil, Nil) =>
    True
  | _ =>
    False
  }
}
