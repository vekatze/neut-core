import {
  this.bool,
  this.either {Left, Right},
  this.file.descriptor {descriptor, stdout},
  this.system {report-system-error, system},
  this.unit {Unit, unit},
}

foreign {
  neut_core_v0_55_write_double(descriptor, float, int) -> int,
  neut_core_v0_55_write_double_line(descriptor, float, int) -> int,
}

define write-float(d: descriptor, x: float, decimals: int) ->> system(unit) {
  let result = magic external neut_core_v0_55_write_double(d, x, decimals);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define write-float-line(d: descriptor, x: float, decimals: int) ->> system(unit) {
  let result = magic external neut_core_v0_55_write_double_line(d, x, decimals);
  if lt-int(result, 0) {
    report-system-error()
  } else {
    Right(Unit)
  }
}

define print-float(x: float, decimals: int) -> unit {
  match write-float(stdout, x, decimals) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}

define print-float-line(x: float, decimals: int) -> unit {
  match write-float-line(stdout, x, decimals) {
  | Left(_) =>
    Unit
  | Right(_) =>
    Unit
  }
}
