import {
  this.bool {bool},
}

data c-int {
| C-Int(int32)
}

inline add-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(add-int32(x, y))
}

inline sub-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(sub-int32(x, y))
}

inline mul-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(mul-int32(x, y))
}

inline div-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(div-int32(x, y))
}

inline and-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(and-int32(x, y))
}

inline or-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(or-int32(x, y))
}

inline xor-c-int(x: c-int, y: c-int) -> c-int {
  let C-Int(x) = x;
  let C-Int(y) = y;
  C-Int(xor-int32(x, y))
}

inline eq-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  eq-int32(x, y)
}

inline ne-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  ne-int32(x, y)
}

inline lt-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  lt-int32(x, y)
}

inline le-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  le-int32(x, y)
}

inline gt-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  gt-int32(x, y)
}

inline ge-c-int(x: c-int, y: c-int) -> bool {
  let C-Int(x) = x;
  let C-Int(y) = y;
  ge-int32(x, y)
}

inline from-c-int(x: c-int) -> int {
  let C-Int(x) = x;
  sext-int32-int(x)
}
