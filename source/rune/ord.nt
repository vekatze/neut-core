import {
  this.bool,
  this.box,
  this.ord {Ord, ord},
  this.ordering {EQ, GT, LT},
}

constant as-ord: ord(rune) {
  Ord{
    compare := {
      (x, y) => {
        if gt-rune(*x, *y) {
          GT
        } else-if lt-rune(*x, *y) {
          LT
        } else {
          EQ
        }
      }
    },
  }
}
