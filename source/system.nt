import {
  this.c-int {c-int},
  this.c-string {c-string, to-string},
  this.either {Left, either},
  this.string {string},
  this.unsafe {cast},
}

foreign {
  neut_core_v0_55_errno() -> c-int,
}

define _get-errno() -> c-int {
  magic external neut_core_v0_55_errno()
}

alias errno {
  c-int
}

data system-error {
| OS-Error(errno)
| Application-Error(string)
}

alias system(a) {
  either(system-error, a)
}

inline get-system-error() ->> system-error {
  OS-Error(_get-errno())
}

inline report-system-error<a>() ->> system(a) {
  Left(get-system-error())
}

foreign {
  strerror(errno) -> pointer,
}

define get-error-message(e: system-error) -> string {
  match e {
  | OS-Error(i) =>
    let c-str = magic external strerror(i);
    to-string(cast<pointer, &c-string>(c-str))
  | Application-Error(message) =>
    message
  }
}
