inline flip<a, b, c>(f: (a, b) -> c) -> (b, a) -> c {
  (y, x) => {
    f(x, y)
  }
}

inline compose<a, b, c>(g: (b) -> c, f: (a) -> b) -> (a) -> c {
  (x) => {
    g(f(x))
  }
}

inline curry<a, b, c>(f: (a, b) -> c) -> (a) -> (b) -> c {
  (x) => {
    (y) => {
      f(x, y)
    }
  }
}

inline uncurry<a, b, c>(f: (a) -> (b) -> c) -> (a, b) -> c {
  (x, y) => {
    f(x)(y)
  }
}

rule-left pipeline {
  inline-meta leaf<a>(_: int) -> '(a) -> a {
    quote {
      (x: a) => {
        x
      }
    }
  },
  inline-meta node-left<a, b, c>(acc: '(a) -> b, g: '(b) -> c) -> '(a) -> c {
    quote {
      (x: a) => {
        let acc-fn = unquote {acc};
        let g-fn = unquote {g};
        g-fn(acc-fn(x))
      }
    }
  },
  inline-meta root<a>(x: 'a) -> 'a {
    x
  },
}
